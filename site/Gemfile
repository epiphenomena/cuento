# The published documentation site (Jekyll). The site is self-contained — it
# ships its own layouts, includes, and stylesheet and uses no remote theme — so
# it builds on plain Jekyll with no network access. Locally,
# `bundle install && bundle exec jekyll serve` works; on GitHub Pages it is
# built via a GitHub Actions workflow (see README.md).
source "https://rubygems.org"

gem "jekyll", "~> 4.4"
