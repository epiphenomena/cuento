{{/*
  p20.2 / p25.4 expense-report editor / detail (GET /expenses/{id}, Perm ExpenseSubmit;
  ownership-enforced -> not-owned/missing is a 404). The report header (subsidiary +
  status), the reviewer's REJECTION REASON when rejected, and the lines. When the report
  is EDITABLE (draft|rejected) the lines render as an AUTO-ROW GRID (p25.4): a single
  bulk-submit form (POST /expenses/{id}/lines) of account/amount/fund/program/memo rows
  that saves the whole set under ONE change (replace-set diff-by-line-id). The grid
  starts with one empty row and the client (expensegrid.js) auto-appends a fresh trailing
  row as the last row is edited; the server drops the trailing empty on save. NO balancing
  requirement, NO min-2, NO DR/CR, NO functional-class -- just a line-id round-trip. A
  submitted/converted report renders the lines READ-ONLY (no grid, no submit). .Page is an
  expenseDetailModel. Account/fund/program/subsidiary names are stored proper nouns; every
  other string via {{t}} (rule 9); amounts via the money formatter (rule 10); the grid's
  auto-append is an external ES module (rule 12: no inline script).
*/ -}}
{{define "expense_detail.tmpl" -}}
{{template "shell-open" (shellTitle . (t "expense.detail.title"))}}
  {{- with .Page}}
  <p><a class="btn btn-ghost" href="/expenses">{{t "expense.detail.back"}}</a></p>
  <h1>{{t "expense.detail.title"}} #{{.ID}}</h1>
  {{if .SubEditable}}
  {{/* p25.3: pick the subsidiary in-page, editable until the first line is added (the
       line accounts/funds are sub-scoped; the store locks it once lines exist). */}}
  {{$curSub := .SubID}}
  {{/* p26.4: the picker AUTO-SUBMITS on change (htmx: hx-post + hx-trigger="change";
       the handler PRG-redirects, and redirectAfterForm sets HX-Redirect on an HX-Request
       so htmx does a full navigation that re-scopes the sub-scoped account/fund options).
       It stays a real <form> so a no-JS client still works -- the <noscript> submit button
       is the fallback (mirrors the register/accounts filter pattern). No inline script. */}}
  <form method="post" action="/expenses/{{.ID}}/subsidiary" class="expense-sub-form">
    <label for="er-sub">{{t "expense.detail.subsidiary"}}</label>
    <select id="er-sub" name="subsidiary_id"
            hx-post="/expenses/{{.ID}}/subsidiary" hx-trigger="change" hx-target="#main" hx-swap="outerHTML">
      {{range .Subs}}<option value="{{.ID}}"{{if eq .ID $curSub}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    <noscript><button type="submit" class="btn btn-ghost">{{t "expense.detail.subsidiary"}}</button></noscript>
    <span class="badge er-status-{{.StatusKey}}">{{t .StatusKey}}</span>
  </form>
  {{else}}
  <p class="hint">{{t "expense.detail.subsidiary"}}: {{.SubName}} &middot;
    <span class="badge er-status-{{.StatusKey}}">{{t .StatusKey}}</span>
  </p>
  {{end}}

  {{if .ErrorMsg}}
  <p class="error" role="alert" id="expense-error">{{.ErrorMsg}}</p>
  {{end}}

  {{if .Rejected}}
  <div class="notice er-rejection" role="status">
    <strong>{{t "expense.detail.rejected_heading"}}</strong>
    <p class="er-reason" id="expense-review-notes">{{.ReviewNotes}}</p>
    <p class="hint">{{t "expense.detail.rejected_hint"}}</p>
  </div>
  {{end}}

  {{/* 8a: the report HEADER reuses the transaction form's main-header layout (.txn-main-header
       + .txn-field, the SAME chrome as transaction_form.tmpl) so the submitter genuinely uses
       "the new transaction form" for framing the report. Three prefilled fields, mirroring the
       txn main-split header:
         - Main ACCOUNT = the report's ap_account_id (the payable), LOCKED for the submitter:
           rendered as read-only static text (the resolved account name), NOT a select. Only
           the reviewer (via convert) may change it. "" = unset -> a hint (the sub had no
           default AP; the reviewer fills it).
         - Main DESCRIPTION = the report's description (creator's display name), LOCKED for the
           submitter: read-only text, NOT an input. The server ALSO refuses any change (it
           passes the stored value through, never the POST field) -- never trust the client.
         - MEMO = editable.
       Date + notes stay editable too. The lock mechanism is static-text rendering (no input +
       a .er-locked class), CSP-safe (no inline styles). When editable it is ONE auto-saving
       form (SetExpenseReportHeader writes date/memo/notes together; description is the stored
       value); it AUTO-SAVES on change (hx-post + hx-trigger="change"). A SIBLING of the grid/
       submit forms (never nested). */}}
  <h2>{{t "expense.header.title"}}</h2>
  {{if .Editable}}
  {{/* FIX 1b: the NOTES textarea moved OUT of this form to below the lines table, but the
       handler (expenseSetHeader) still writes date/memo/notes together in ONE call, so a
       partial post would blank the untouched ones. Both auto-saving surfaces therefore
       carry the OTHER's fields via hx-include: this header form (date/memo) pulls #er-notes;
       the relocated notes textarea pulls #er-date,#er-memo. So every save posts all three. */}}
  <form method="post" action="/expenses/{{.ID}}/header" class="expense-header-form"
        hx-post="/expenses/{{.ID}}/header" hx-trigger="change" hx-target="#main" hx-swap="outerHTML"
        hx-include="#er-notes">
    <div class="txn-main-header">
      {{/* Main account (AP payable): LOCKED read-only text for the submitter (reviewer edits). */}}
      <div class="txn-field txn-main-account-field">
        <label id="er-main-account-label">{{t "expense.main.account"}}<span class="help-tip" tabindex="0" role="img" title="{{t "expense.main.account_locked_hint"}}" aria-label="{{t "expense.main.account_locked_hint"}}">?</span></label>
        {{if .APAccountName}}<span class="er-locked" id="er-main-account" aria-labelledby="er-main-account-label">{{.APAccountName}}</span>{{else}}<span class="er-locked muted" id="er-main-account" aria-labelledby="er-main-account-label">{{t "expense.main.account_none"}}</span>{{end}}
      </div>
      {{/* Main description (creator's name): LOCKED read-only text for the submitter.
           8b: the field-guidance "your name; reviewer can change it" hint moved from an
           inline <p class="hint"> to a .help-tip on the label (the same affordance the txn
           form uses), so the header row stays tight and the guidance is on-demand. */}}
      <div class="txn-field txn-field-grow txn-main-desc-field">
        <label id="er-description-label">{{t "expense.header.description"}}<span class="help-tip" tabindex="0" role="img" title="{{t "expense.main.description_locked_hint"}}" aria-label="{{t "expense.main.description_locked_hint"}}">?</span></label>
        {{if .Description}}<span class="er-locked" id="er-description" aria-labelledby="er-description-label">{{.Description}}</span>{{else}}<span class="er-locked muted" id="er-description" aria-labelledby="er-description-label">&mdash;</span>{{end}}
      </div>
      {{/* Date: editable. FIX 1a: the SAME reusable date widget every other date field uses
           (datefield partial + datefield.js -> autoformat-as-you-type + calendar picker
           button, per-user format, rule 10). Keeps id "er-date" and name "date" (the handler
           reads r.PostFormValue("date"); e2e/JS query #er-date). Format "" -> datefield.js
           uses the global per-user format (as register/report do). */}}
      <div class="txn-field">
        <label for="er-date">{{t "expense.header.date"}}</label>
        {{template "datefield" (datefield "er-date" "date" .Date (t "expense.header.date_hint") "" "" false)}}
      </div>
      {{/* Memo: EDITABLE. 8b: mirrors the txn-form layout -- the memo now sits DOWN next to
           the date (account -> description -> date -> memo) and grows wider (txn-field-grow +
           the txn-memo-header width class). Keeps id "er-memo" + name "memo" so the change-
           triggered auto-save and the notes form's hx-include="#er-date,#er-memo" still bind. */}}
      <div class="txn-field txn-field-grow">
        <label for="er-memo">{{t "expense.header.memo"}}</label>
        <input type="text" name="memo" id="er-memo" class="txn-memo-header" value="{{.Memo}}" autocomplete="off">
      </div>
    </div>
    <noscript><button type="submit" class="btn btn-ghost">{{t "expense.header.save"}}</button></noscript>
  </form>
  {{else}}
  {{/* Read-only header (submitted/converted): the stored values, an em-dash when empty. */}}
  <dl class="expense-header-view">
    <dt>{{t "expense.main.account"}}</dt>
    <dd id="er-main-account-view">{{if .APAccountName}}{{.APAccountName}}{{else}}<span class="muted">{{t "expense.main.account_none"}}</span>{{end}}</dd>
    <dt>{{t "expense.header.date"}}</dt>
    <dd id="er-date-view">{{if .Date}}{{.Date}}{{else}}<span class="muted">&mdash;</span>{{end}}</dd>
    <dt>{{t "expense.header.description"}}</dt>
    <dd id="er-description-view">{{if .Description}}{{.Description}}{{else}}<span class="muted">&mdash;</span>{{end}}</dd>
    <dt>{{t "expense.header.memo"}}</dt>
    <dd id="er-memo-view">{{if .Memo}}{{.Memo}}{{else}}<span class="muted">&mdash;</span>{{end}}</dd>
    <dt>{{t "expense.header.notes"}}</dt>
    <dd id="er-notes-view">{{if .Notes}}{{.Notes}}{{else}}<span class="muted">&mdash;</span>{{end}}</dd>
  </dl>
  {{end}}

  <h2>{{t "expense.detail.lines"}}</h2>
  {{if .Editable}}
  {{/* p25.4 auto-row grid: ONE bulk-submit form. Each row round-trips its line_id (0 =
       a new line to insert; >0 = an existing line to update); the client auto-appends a
       fresh trailing empty row as the last row is edited; the server drops the trailing
       empty on save. This grid form is a SIBLING of the submit/discard forms below (no
       nested forms). */}}
  {{/* p26.38: data-sub carries the report's subsidiary so the per-line description
       autocomplete/prefill is scoped to it EVEN when the sub picker is locked (a saved
       multi-line report drops #er-sub, so descfield.subOf() has no select to read). */}}
  <form method="post" action="/expenses/{{.ID}}/lines" id="expense-grid-form" data-sub="{{.SubID}}" data-user-program="{{.UserProgram}}" data-account-missing-msg="{{t "error.expense.account_not_offered"}}">
    {{/* p26.32 / p28 two-row line layout: each line is its OWN <tbody class="el-row"> holding
         a .el-row-main (description / account / amount / error / delete) and a .el-row-more
         (fund / program / memo -- memo spans to the right edge). Grouping by <tbody> bands
         both physical rows for the per-line zebra (nth-of-type, self-maintaining) and keeps
         every id-keyed selector working (they descend the tbody). The grid is 14 fixed-layout
         columns; the stacked header labels BOTH rows band-for-band (Fund under Description 5,
         Program under Account 4, Memo under Amount 5). The trailing 2 columns (error + delete)
         are pinned narrow by the <colgroup>. */}}
    <table class="expense-lines-table txn-grid txn-grid-2row">
      {{/* p28: only DELETE is pinned narrow; the error column stays flexible so its message
           is readable (see transaction_form.tmpl). */}}
      <colgroup>
        <col span="13">
        <col class="txn-col-util">
      </colgroup>
      <thead>
        <tr>
          {{/* p26.23: description is the FIRST column (before Account). p28: each header is a
               stacked two-line label -- line 1 the row-1 field, line 2 the row-2 field beneath. */}}
          <th colspan="5"><span class="txn-hdr-main">{{t "expense.line.col.description"}}<span class="help-tip" tabindex="0" role="img" title="{{t "txn.main.description_help"}}" aria-label="{{t "txn.main.description_help"}}">?</span></span><span class="txn-hdr-sub">{{t "expense.line.col.fund"}}</span></th>
          <th colspan="4"><span class="txn-hdr-main">{{t "expense.line.col.account"}}</span><span class="txn-hdr-sub">{{t "expense.line.col.program"}}</span></th>
          <th colspan="5"><span class="txn-hdr-main">{{t "expense.line.col.amount"}}</span><span class="txn-hdr-sub">{{t "expense.line.col.memo"}}</span></th>
        </tr>
      </thead>
      {{$page := .}}
      {{range $i, $l := .Lines}}
      <tbody class="expense-line-row el-row" data-row="{{$i}}">
        <tr class="el-row-main">
          {{/* p26.23: per-line free-text description is the FIRST column (before Account).
               Autocomplete + prefill, magnitude amount mode (sign derived server-side). */}}
          <td class="txn-cell el-desc-cell" colspan="5">
            <input type="hidden" name="line_id_{{$i}}" id="el-lineid-{{$i}}" value="{{if $l.ID}}{{$l.ID}}{{end}}">
            <div class="desc-field">
              <input type="text" name="description_{{$i}}" id="el-desc-{{$i}}" class="el-desc js-descfield"
                     value="{{$l.Description}}" autocomplete="off"
                     data-desc-container="el-desc-list-{{$i}}" data-desc-mode="magnitude"
                     placeholder="{{t "txn.description_hint"}}">
              <div class="desc-suggest-box" id="el-desc-list-{{$i}}" hidden></div>
            </div>
          </td>
          <td class="txn-cell el-account-cell" colspan="4">
            <select name="account_{{$i}}" id="el-account-{{$i}}" class="el-account combo-input">
              <option value="0">{{t "expense.line.form.account_none"}}</option>
              {{/* p26.74: group the R/E account options by type (optgroup); only the
                   Revenue + Expenses groups appear here since the grid offers R/E leaves. */}}
              {{range (expenseAccountsByType $page.Accounts)}}<optgroup label="{{t .LabelKey}}">
              {{range .Options}}<option value="{{.ID}}" {{if .Unavailable}}data-unavailable="1" data-path="{{.Path}} {{t "txn.account.unavailable_suffix"}}"{{else}}data-path="{{.Path}}"{{end}}{{if eq .ID $l.AccountID}} selected{{end}}>{{.Path}}{{if .Unavailable}} {{t "txn.account.unavailable_suffix"}}{{end}}</option>
              {{end}}</optgroup>
              {{end}}
            </select>
          </td>
          <td class="txn-cell el-amount-cell" colspan="3">
            <input type="text" name="amount_{{$i}}" id="el-amount-{{$i}}" class="el-amount amount" value="{{$l.AmountInput}}" inputmode="decimal">
          </td>
          {{/* p28: the per-line error cell + delete-x trail ROW 1 (after amount). type="button"
               so it never submits the grid; expensegrid.js re-indexes the surviving rows on
               click and resets the only/last row in place (never drops to zero). The two
               columns are pinned narrow by the <colgroup> so delete is a tight utility cell. */}}
          <td class="el-row-error" colspan="1">{{if $l.ErrorKey}}<span class="field-error" role="alert">{{t $l.ErrorKey}}</span>{{end}}</td>
          <td class="el-delete-cell" colspan="1">
            <button type="button" class="btn btn-ghost el-delete" aria-label="{{t "common.delete_row_help"}}" title="{{t "common.delete_row_help"}}">&times;</button>
          </td>
        </tr>
        <tr class="el-row-more">
          {{/* p28: row 2 aligns band-for-band under row 1 -- Fund (5) under Description,
               Program (4) under Account, Memo (5) under Amount+error+delete (memo now extends
               to the row's right edge). Sum = 5+4+5 = 14. */}}
          <td class="txn-cell el-fund-cell" colspan="5">
            <select name="fund_{{$i}}" id="el-fund-{{$i}}" class="el-fund combo-input">
              <option value="0">{{t "expense.line.unrestricted"}}</option>
              {{range $page.Funds}}<option value="{{.ID}}"{{if eq .ID $l.FundID}} selected{{end}}>{{.Name}}</option>
              {{end}}
            </select>
          </td>
          <td class="txn-cell el-program-cell" colspan="4">
            <select name="program_{{$i}}" id="el-program-{{$i}}" class="el-program combo-input">
              <option value="0">{{t "expense.line.form.program_none"}}</option>
              {{range $page.Programs}}<option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $l.ProgramID}} selected{{end}}>{{.Name}}</option>
              {{end}}
            </select>
          </td>
          <td class="txn-cell el-memo-cell" colspan="5">
            <input type="text" name="memo_{{$i}}" id="el-memo-{{$i}}" class="el-memo" value="{{$l.Memo}}" autocomplete="off">
          </td>
        </tr>
      </tbody>
      {{end}}
    </table>
    <input type="hidden" name="rows" id="expense-rows-count" value="{{len .Lines}}">
    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="expense-save-lines">{{t "expense.detail.save_lines"}}</button>
    </div>
  </form>
  {{else}}
  {{/* Read-only lines (submitted/converted): the resolved-name display fields. */}}
  <table class="expense-lines-table txn-grid">
    <thead>
      <tr>
        <th>{{t "expense.line.col.account"}}</th>
        <th>{{t "expense.line.col.amount"}}</th>
        <th>{{t "expense.line.col.fund"}}</th>
        <th>{{t "expense.line.col.program"}}</th>
        <th>{{t "expense.line.col.memo"}}</th>
      </tr>
    </thead>
    <tbody>
      {{range .Lines}}
      <tr class="expense-line-row" id="expense-line-row-{{.ID}}">
        <td class="el-account">{{.AcctName}}</td>
        <td class="el-amount amount">{{.AmountFmt}}</td>
        <td class="el-fund">{{if .FundName}}{{.FundName}}{{else}}<span class="muted">{{t "expense.line.unrestricted"}}</span>{{end}}</td>
        <td class="el-program">{{if .ProgName}}{{.ProgName}}{{else}}<span class="muted">&mdash;</span>{{end}}</td>
        <td class="el-memo">{{.Memo}}</td>
      </tr>
      {{else}}
      <tr><td colspan="5">{{t "expense.detail.no_lines"}}</td></tr>
      {{end}}
    </tbody>
  </table>
  {{end}}

  {{if .Editable}}
  {{/* FIX 1b: NOTES now render BELOW the lines table (were above it, in the header form).
       Its own auto-saving form posting to /header (the same handler): hx-include pulls the
       header's #er-date + #er-memo so a notes-only change still carries them (the handler
       writes date/memo/notes together -- see the header form's hx-include note). Keeps name
       "notes" + id "er-notes" and the auto-save-on-change behavior intact. A SIBLING of the
       grid/submit forms (never nested). */}}
  <form method="post" action="/expenses/{{.ID}}/header" class="expense-notes-form"
        hx-post="/expenses/{{.ID}}/header" hx-trigger="change" hx-target="#main" hx-swap="outerHTML"
        hx-include="#er-date,#er-memo">
    <div class="txn-notes-field">
      <label for="er-notes">{{t "expense.header.notes"}}</label>
      <textarea name="notes" id="er-notes" rows="4">{{.Notes}}</textarea>
    </div>
    <noscript><button type="submit" class="btn btn-ghost">{{t "expense.header.save"}}</button></noscript>
  </form>
  {{end}}

  {{if .Editable}}
  <div class="expense-submit">
    {{if .Rejected}}
    <form method="post" action="/expenses/{{.ID}}/resubmit" class="inline">
      <button type="submit" class="btn btn-primary" id="expense-resubmit">{{t "expense.detail.resubmit"}}</button>
    </form>
    {{else}}
    <form method="post" action="/expenses/{{.ID}}/submit" class="inline">
      <button type="submit" class="btn btn-primary" id="expense-submit">{{t "expense.detail.submit"}}</button>
    </form>
    {{/* p25.3: discard the draft (hard-deletes it + any lines). Draft-only. */}}
    <form method="post" action="/expenses/{{.ID}}/discard" class="inline">
      <button type="submit" class="btn btn-ghost" id="expense-discard">{{t "expense.discard"}}</button>
    </form>
    {{end}}
    <p class="hint">{{t "expense.detail.submit_hint"}}</p>
  </div>
  {{else}}
  <p class="hint" id="expense-readonly">{{t "expense.detail.readonly"}}</p>
  {{end}}
  {{if .Editable}}
  {{/* p25.4 grid auto-append (rule 12: external ES module, no inline script). Reuses the
       tested isRowEmpty predicate; mirrors txneditor.js's trailing-empty-row behavior. */}}
  <script type="module" src="{{asset "expensegrid.js"}}"></script>
  {{end}}
  {{- end}}
{{template "shell-close" .}}
{{- end}}
