{{/*
  p20.2 expense-report line form partial ("expense-line-form"). SINGLE SOURCE of the
  line-editor region: the report detail renders the "New line" trigger inside
  #expense-line-form; GET /expenses/{id}/lines/new and .../lines/{lid}/edit swap THIS
  partial in, and a failed POST re-renders it at 422 (stable ids across swaps, the
  p10.3 form-error convention). The dot is always an expenseLineFormModel.

  SUB-SCOPED SELECTORS (reused from the phase-12 / budget-line editor): the account
  options are the REVENUE/EXPENSE LEAVES in the REPORT's subsidiary; the fund options
  are ActiveFunds(that sub); programs are all active. The report's subsidiary is FIXED
  (one sub per report, chosen at creation), so -- unlike the budget-line editor --
  there is NO subsidiary picker and NO sub-change hx-get re-filter.

  NO balancing requirement and NO functional-class / DR-CR machinery (that is the
  reviewer's job at convert, p20.3): a plain POSITIVE amount magnitude (the stored
  sign is derived from the account type server-side). hx-post targets /expenses/{rid}/
  lines (create) when .ID is 0, else /expenses/{rid}/lines/{id} (edit). Field errors
  come from .Errors (formErrors), i18n KEYS via {{t}} (rule 9); amounts entered in the
  user's number format (rule 10). No inline script/style (strict CSP, rule 12).
*/ -}}
{{define "expense-line-form" -}}
<form id="expense-line-form" class="expense-line-form"
      hx-post="{{if .ID}}/expenses/{{.ReportID}}/lines/{{.ID}}{{else}}/expenses/{{.ReportID}}/lines{{end}}"
      hx-target="#expense-line-form" hx-swap="outerHTML">

  <h3>{{if .ID}}{{t "expense.line.form.edit_title"}}{{else}}{{t "expense.line.form.new_title"}}{{end}}</h3>

  <div class="field">
    <label for="elf-account">{{t "expense.line.form.account"}}</label>
    <select id="elf-account" name="account_id"
      {{- if eq .Errors.FirstInvalid "account_id"}} autofocus{{end}}>
      <option value="0">{{t "expense.line.form.account_none"}}</option>
      {{range .Accounts}}<option value="{{.ID}}"{{if eq .ID $.AccountID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    <p class="hint">{{t "expense.line.form.account_hint"}}</p>
    {{with .Errors.ErrorKey "account_id"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="elf-amount">{{t "expense.line.form.amount"}}</label>
    <input id="elf-amount" name="amount" type="text" value="{{.Amount}}" inputmode="decimal"
      {{- if eq .Errors.FirstInvalid "amount"}} autofocus{{end}}>
    <p class="hint">{{t "expense.line.form.amount_hint"}}</p>
    {{with .Errors.ErrorKey "amount"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="elf-fund">{{t "expense.line.form.fund"}}</label>
    <select id="elf-fund" name="fund_id">
      <option value="0">{{t "expense.line.unrestricted"}}</option>
      {{range .Funds}}<option value="{{.ID}}"{{if eq .ID $.FundID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </div>

  <div class="field">
    <label for="elf-program">{{t "expense.line.form.program"}}</label>
    <select id="elf-program" name="program_id">
      <option value="0">{{t "expense.line.form.program_none"}}</option>
      {{range .Programs}}<option value="{{.ID}}"{{if eq .ID $.ProgramID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </div>

  <div class="field">
    <label for="elf-memo">{{t "expense.line.form.memo"}}</label>
    <input id="elf-memo" name="memo" type="text" value="{{.Memo}}">
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
    <a class="btn btn-ghost" href="/expenses/{{.ReportID}}">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
