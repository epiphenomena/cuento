{{/*
  p20.2 submitter "my reports" list (GET /expenses, Perm ExpenseSubmit). The current
  user's OWN expense reports with status; a rejected report shows the reviewer's
  reason and links to the editor to fix + resubmit. p25.3: "New report" is a plain
  POST (the subsidiary is chosen on the report page now, not here); a DRAFT row also
  carries a Discard action. .Page is an expensesPageModel. Every string via {{t}}
  (rule 9); subsidiary names are stored proper nouns; no inline script (rule 12).
*/ -}}
{{define "expenses.tmpl" -}}
{{template "shell-open" (shellTitle . (t "expense.list.title"))}}
  {{- with .Page}}
  <h1>{{t "expense.list.title"}}</h1>
  <p class="hint">{{t "expense.list.intro"}}</p>

  {{/* New report: a plain POST creates a draft (in the submitter's default subsidiary)
       and redirects to the report page, where the sub can be changed until the first
       line is added (p25.3). */}}
  <form method="post" action="/expenses" class="expense-new-form">
    <button type="submit" class="btn btn-primary">{{t "expense.new.btn"}}</button>
  </form>

  {{/* 8b: a clear, scannable table keyed on the report's stored main-split header values
       (date/description/memo) + status + actions. The date is pre-formatted per the user's
       DateFormat in the handler (rule 10); an unset date renders as a blank cell. */}}
  <table class="expense-reports-table">
    <thead>
      <tr>
        <th>{{t "expense.list.col.date"}}</th>
        <th>{{t "expense.list.col.description"}}</th>
        <th>{{t "expense.list.col.memo"}}</th>
        <th>{{t "expense.list.col.status"}}</th>
        <th>{{t "expense.list.col.actions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{range .Rows}}
      <tr class="expense-report-row" id="expense-report-row-{{.ID}}">
        <td class="er-date">{{.Date}}</td>
        <td class="er-description">{{.Description}}</td>
        <td class="er-memo">{{.Memo}}</td>
        <td class="er-status">
          <span class="badge er-status-{{.StatusKey}}">{{t .StatusKey}}</span>
          {{if .Rejected}}<p class="er-reason" role="note">{{t "expense.list.reason"}}: {{.ReviewNotes}}</p>{{end}}
        </td>
        <td class="er-actions">
          <a class="btn btn-ghost" href="/expenses/{{.ID}}">{{t "expense.list.open"}}</a>
          {{if .Draft}}
          {{/* p25.3: discard a draft (hard-deletes it + any lines). */}}
          <form method="post" action="/expenses/{{.ID}}/discard" class="inline">
            <button type="submit" class="btn btn-ghost">{{t "expense.discard"}}</button>
          </form>
          {{end}}
        </td>
      </tr>
      {{else}}
      <tr><td colspan="5">{{t "expense.list.empty"}}</td></tr>
      {{end}}
    </tbody>
  </table>
  {{- end}}
{{template "shell-close" .}}
{{- end}}
