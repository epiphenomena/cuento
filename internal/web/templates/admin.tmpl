{{/*
  p13.2 Admin index (GET /admin, Admin). The section hub linking every admin area:
  users, subsidiaries, currencies, and org settings. Replaces the p10.2 stub. Reuses
  the base.tmpl shell partials; every string via {{t}} (rule 9); no inline script
  (rule 12).
*/ -}}
{{define "admin.tmpl" -}}
{{template "shell-open" (shellTitle . (t "nav.admin"))}}
  <h1>{{t "nav.admin"}}</h1>
  <p class="hint">{{t "admin.intro"}}</p>
  <ul class="admin-links">
    <li><a href="/admin/users">{{t "admin.users.title"}}</a></li>
    <li><a href="/admin/subsidiaries">{{t "subsidiaries.title"}}</a></li>
    <li><a href="/admin/currencies">{{t "admin.currencies.title"}}</a></li>
    <li><a href="/admin/org">{{t "org.title"}}</a></li>
  </ul>
{{template "shell-close" .}}
{{- end}}
