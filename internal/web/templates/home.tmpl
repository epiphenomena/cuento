{{define "home.tmpl" -}}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{t "home.title"}}</title>
</head>
<body>
  <main>
    <h1>{{t "app.name"}}</h1>
    <p>{{t "home.welcome"}}</p>
    <form method="post" action="/logout">
      <button type="submit">{{t "auth.sign_out"}}</button>
    </form>
  </main>
</body>
</html>
{{- end}}
