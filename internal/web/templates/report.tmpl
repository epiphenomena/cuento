{{/*
  p15.1 generic report page (/reports/{id}, ReportGroup(group)). ONE template
  renders ANY report: p15.3–p15.11 add reports without touching it. A self-contained
  shell page; .Page is a reportPageModel.

  Structure:
    - the shared PARAMS FORM: a plain <form method="get"> (no JS, strict CSP -- rule
      12) that submits the params as query string back to the same report. The
      SUBSIDIARY SCOPE selector is ALWAYS present (every report is scoped, D18); the
      as-of / period (from–to) / granularity / target-currency controls render only
      when the report's ParamsSpec declares them. Dates are plain text inputs (never
      input[type=date] -- rule 10/12); the placeholder shows the resolved value.
    - a CSV export link (an <a href>, no JS) carrying the current params.
    - the rendered TABLE: localized column headers with alignment, and typed cells
      already formatted per the user's settings (rule 10). Rows carry indent (tree
      depth), subtotal/total emphasis, and the D19 warning kind.

  Every label via {{t}} (rule 9); amounts/dates pre-formatted in the handler; names
  are stored proper nouns rendered verbatim.
*/ -}}
{{define "report.tmpl" -}}
{{template "shell-open" (shellTitle . .Page.Title)}}
  {{- with .Page}}
  <h1>{{.Title}}</h1>

  <form class="report-params" method="get" action="/reports/{{.Params.ReportID}}">
    {{/* p26.52: the fieldset LEGEND labels the box ("Filters"); each control keeps its
         OWN inner label (no more doubled "Subsidiary scope"). Each label+control is
         wrapped in a .report-field flex unit so the label always stays with its input
         and the From/To pair flows together (never orphaning a label on its own row). */}}
    <fieldset class="report-scope">
      <legend>{{t "reports.params.filters"}}</legend>
      <div class="report-field">
        <label for="rp-scope">{{t "reports.params.scope"}}</label>
        <select id="rp-scope" name="scope" class="report-scope-select">
          {{- range .Params.Scopes}}
          <option value="{{.ID}}"{{if .Selected}} selected{{end}}>{{.Name}}</option>
          {{- end}}
        </select>
      </div>

      {{if .Params.ShowAsOf}}
      <div class="report-field">
        <label for="rp-asof">{{t "reports.params.asof"}}</label>
        <input type="text" id="rp-asof" name="asof" value="{{.Params.AsOf}}"
               inputmode="numeric" autocomplete="off">
      </div>
      {{end}}

      {{if .Params.ShowPeriod}}
      <div class="report-field">
        <label for="rp-from">{{t "reports.params.from"}}</label>
        <input type="text" id="rp-from" name="from" class="js-datefield" value="{{.Params.From}}"
               inputmode="numeric" autocomplete="off">
      </div>
      <div class="report-field">
        <label for="rp-to">{{t "reports.params.to"}}</label>
        <input type="text" id="rp-to" name="to" class="js-datefield" value="{{.Params.To}}"
               inputmode="numeric" autocomplete="off">
      </div>
      {{end}}

      {{if .Params.ShowGranularity}}
      <div class="report-field">
        <label for="rp-gran">{{t "reports.params.granularity"}}</label>
        <select id="rp-gran" name="granularity">
          <option value="none"{{if eq .Params.Granularity "none"}} selected{{end}}>{{t "reports.gran.none"}}</option>
          <option value="week"{{if eq .Params.Granularity "week"}} selected{{end}}>{{t "reports.gran.week"}}</option>
          <option value="month"{{if eq .Params.Granularity "month"}} selected{{end}}>{{t "reports.gran.month"}}</option>
          <option value="quarter"{{if eq .Params.Granularity "quarter"}} selected{{end}}>{{t "reports.gran.quarter"}}</option>
          <option value="year"{{if eq .Params.Granularity "year"}} selected{{end}}>{{t "reports.gran.year"}}</option>
        </select>
      </div>
      {{end}}

      {{if .Params.ShowCurrency}}
      <div class="report-field">
        <label for="rp-ccy">{{t "reports.params.currency"}}</label>
        <select id="rp-ccy" name="currency">
          {{- range .Params.Currencies}}
          <option value="{{.Code}}"{{if .Selected}} selected{{end}}>{{.Code}}</option>
          {{- end}}
        </select>
      </div>
      {{end}}

      {{if .Params.ShowDetail}}
      <div class="report-field">
        <label for="rp-detail">{{t "reports.params.detail"}}</label>
        <select id="rp-detail" name="detail" class="report-detail-select">
          <option value=""{{if ne .Params.Detail "currency"}} selected{{end}}>{{t "reports.detail.converted"}}</option>
          <option value="currency"{{if eq .Params.Detail "currency"}} selected{{end}}>{{t "reports.detail.currency"}}</option>
        </select>
      </div>
      {{end}}

      {{if .Params.ShowAccount}}
      <div class="report-field">
        <label for="rp-account">{{t "reports.params.account"}}</label>
        <select id="rp-account" name="account" class="report-account-select">
          <option value="0"{{if eq .Params.Account 0}} selected{{end}}>{{t "reports.account.choose"}}</option>
          {{- range .Params.Accounts}}
          <option value="{{.ID}}"{{if eq .ID $.Page.Params.Account}} selected{{end}}>{{.Name}}</option>
          {{- end}}
        </select>
      </div>
      {{end}}

      {{if .Params.ShowFund}}
      <div class="report-field">
        <label for="rp-fund">{{t "reports.params.fund"}}</label>
        <select id="rp-fund" name="fund" class="report-fund-select">
          <option value="0"{{if eq .Params.Fund 0}} selected{{end}}>{{t "reports.fund_activity.all_funds"}}</option>
          {{- range .Params.Funds}}
          <option value="{{.ID}}"{{if eq .ID $.Page.Params.Fund}} selected{{end}}>{{.Name}}</option>
          {{- end}}
        </select>
      </div>
      {{end}}

      {{if .Params.ShowProgram}}
      <div class="report-field">
        <label for="rp-program">{{t "reports.params.program"}}</label>
        <select id="rp-program" name="program" class="report-program-select">
          <option value="0"{{if eq .Params.Program 0}} selected{{end}}>{{t "reports.program_statement.all_programs"}}</option>
          {{- range .Params.Programs}}
          <option value="{{.ID}}"{{if eq .ID $.Page.Params.Program}} selected{{end}}>{{.Name}}</option>
          {{- end}}
        </select>
      </div>
      {{end}}

      {{if .Params.ShowRecon}}
      <div class="report-field">
        <label for="rp-recon">{{t "reports.params.reconciliation"}}</label>
        <select id="rp-recon" name="reconciliation" class="report-recon-select">
          <option value="0"{{if eq .Params.Recon 0}} selected{{end}}>{{t "reports.reconciliation_statement.choose"}}</option>
          {{- range .Params.Recons}}
          <option value="{{.ID}}"{{if eq .ID $.Page.Params.Recon}} selected{{end}}>{{.Label}}</option>
          {{- end}}
        </select>
      </div>
      {{end}}

      {{if .Params.ShowBudget}}
      <div class="report-field">
        <label for="rp-budget">{{t "reports.params.budget"}}</label>
        <select id="rp-budget" name="budget" class="report-budget-select">
          <option value="0"{{if eq .Params.Budget 0}} selected{{end}}>{{t "reports.budget.choose"}}</option>
          {{- range .Params.Budgets}}
          <option value="{{.ID}}"{{if eq .ID $.Page.Params.Budget}} selected{{end}}>{{.Label}}</option>
          {{- end}}
        </select>
      </div>
      {{end}}

      <button type="submit" class="btn btn-primary report-run">{{t "reports.params.run"}}</button>
    </fieldset>
  </form>

  <p class="report-export">
    <a href="{{.CSVHref}}" class="report-csv-link" download>{{t "reports.export.csv"}}</a>
  </p>

  {{/* p26.26: reports presenting a NESTED account hierarchy (trial balance, balance
       sheet, income statement, functional expenses) reuse the p26.25 collapse/expand
       tree control. The controls carry `hidden` (no-JS shows the full tree with inert
       hidden buttons); treetable.js reveals + wires them. Non-tree reports skip this
       block and emit no data-depth, so their tables render byte-identically. */}}
  {{if .Tree}}
  <div class="report-controls tree-controls">
    <button type="button" class="btn btn-ghost tree-collapse-all" hidden>{{t "tree.collapse_all"}}</button>
    <button type="button" class="btn btn-ghost tree-expand-level" hidden>{{t "tree.expand_level"}}</button>
    <button type="button" class="btn btn-ghost tree-expand-all" hidden>{{t "tree.expand_all"}}</button>
  </div>
  {{end}}

  <table class="report-table{{if .Tree}} tree-table{{end}}">
    <thead>
      <tr>
        {{- range .Table.Columns}}
        <th{{if .Right}} class="amount"{{end}}>{{.Header}}</th>
        {{- end}}
      </tr>
    </thead>
    <tbody>
      {{- range .Table.Rows}}
      <tr class="report-row report-indent-{{.Indent}}{{if .Subtotal}} report-subtotal{{end}}{{if .Total}} report-total{{end}}{{if .Warning}} report-warning{{end}}"{{if $.Page.Tree}} data-depth="{{.Indent}}"{{end}}{{if .Warning}} role="alert"{{end}}>
        {{- range .Cells}}
        <td{{if .Right}} class="amount"{{end}}>{{if .Href}}<a class="report-drill-link" href="{{.Href}}">{{.Text}}</a>{{else}}{{.Text}}{{end}}</td>
        {{- end}}
      </tr>
      {{- else}}
      <tr class="report-empty"><td colspan="{{len .Table.Columns}}">{{t "reports.empty"}}</td></tr>
      {{- end}}
    </tbody>
  </table>

  {{if .Tree}}
  {{/* p26.26: the reusable tree module (p26.25). Loaded on the PAGE; self-inits on
       DOMContentLoaded and re-runs on htmx:afterSwap. It enhances every
       table.tree-table, looking up the sibling .tree-controls container. */}}
  <script type="module" src="{{asset "treetable.js"}}"></script>
  {{end}}
  {{- end}}
{{template "shell-close" .}}
{{- end}}
