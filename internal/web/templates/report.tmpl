{{/*
  p15.1 generic report page (/reports/{id}, ReportGroup(group)). ONE template
  renders ANY report: p15.3–p15.11 add reports without touching it. A self-contained
  shell page; .Page is a reportPageModel.

  Structure:
    - the shared PARAMS FORM: a plain <form method="get"> (no JS, strict CSP -- rule
      12) that submits the params as query string back to the same report. The
      SUBSIDIARY SCOPE selector is ALWAYS present (every report is scoped, D18); the
      as-of / period (from–to) / granularity / target-currency controls render only
      when the report's ParamsSpec declares them. Dates are plain text inputs (never
      input[type=date] -- rule 10/12); the placeholder shows the resolved value.
    - a CSV export link (an <a href>, no JS) carrying the current params.
    - the rendered TABLE: localized column headers with alignment, and typed cells
      already formatted per the user's settings (rule 10). Rows carry indent (tree
      depth), subtotal/total emphasis, and the D19 warning kind.

  Every label via {{t}} (rule 9); amounts/dates pre-formatted in the handler; names
  are stored proper nouns rendered verbatim.
*/ -}}
{{/* p26.76: the report FILTER FORM, extracted to a shared partial so ONE definition
     serves both locations — inline in the page body (dense reports, .FiltersInline) and
     the second-level nav bar (SubNavControls="report", most reports). Dot is a
     paramsForm. It is a plain <form method="get"> submitting the params back to the same
     report (no JS, strict CSP — rule 12; no results-swap — reports have no fragment). The
     SUBSIDIARY SCOPE selector is ALWAYS present (D18); the other controls render only
     when the report's spec declares them. Relocating the form does not change its
     inputs/names, so params, persistence, and the CSV link are unchanged. */ -}}
{{/* p26.90: the filter form AUTO-APPLIES on change — hx-get back to the same report,
     swapping ONLY #report-results (hx-target). Every control lives inside the <form>, so
     htmx serializes them all into the GET (no hx-include needed). hx-push-url keeps the
     URL in sync so reload/bookmark/back replay the same filter (the report's ONLY
     persistence is the query string). hx-sync="this:replace" ABORTS any in-flight request
     when a new change fires, so rapid changes settle on the LATEST response (ordering
     correctness). No-JS: the form is still a plain method="get" GET, and the Run button —
     kept in <noscript> — submits it (full reload). */ -}}
{{define "report-filters" -}}
{{- /* Dot is a paramsForm. */ -}}
<form class="report-params" method="get" action="/reports/{{.ReportID}}"
      hx-get="/reports/{{.ReportID}}" hx-trigger="change" hx-target="#report-results"
      hx-swap="outerHTML" hx-push-url="true" hx-sync="this:replace">
  {{/* p26.86: filters live in the second-level nav bar now, so the "Filters" legend is
       DROPPED — with the controls in the subnav their purpose is obvious. Each control
       keeps its OWN inner label. Each label+control is a .report-field flex unit so the
       label always stays with its input and the From/To pair flows together. */}}
  <fieldset class="report-scope">
    <div class="report-field">
      <label for="rp-scope">{{t "reports.params.scope"}}</label>
      <select id="rp-scope" name="scope" class="report-scope-select">
        {{- range .Scopes}}
        <option value="{{.ID}}"{{if .Selected}} selected{{end}}>{{.Name}}</option>
        {{- end}}
      </select>
    </div>

    {{if .ShowAsOf}}
    <div class="report-field">
      <label for="rp-asof">{{t "reports.params.asof"}}</label>
      {{template "datefield" (datefield "rp-asof" "asof" .AsOf "" "" "" false)}}
    </div>
    {{end}}

    {{if .ShowPeriod}}
    <div class="report-field">
      <label for="rp-from">{{t "reports.params.from"}}</label>
      {{template "datefield" (datefield "rp-from" "from" .From "" "" "" false)}}
    </div>
    <div class="report-field">
      <label for="rp-to">{{t "reports.params.to"}}</label>
      {{template "datefield" (datefield "rp-to" "to" .To "" "" "" false)}}
    </div>
    {{end}}

    {{if .ShowGranularity}}
    <div class="report-field">
      <label for="rp-gran">{{t "reports.params.granularity"}}</label>
      <select id="rp-gran" name="granularity">
        <option value="none"{{if eq .Granularity "none"}} selected{{end}}>{{t "reports.gran.none"}}</option>
        <option value="week"{{if eq .Granularity "week"}} selected{{end}}>{{t "reports.gran.week"}}</option>
        <option value="month"{{if eq .Granularity "month"}} selected{{end}}>{{t "reports.gran.month"}}</option>
        <option value="quarter"{{if eq .Granularity "quarter"}} selected{{end}}>{{t "reports.gran.quarter"}}</option>
        <option value="year"{{if eq .Granularity "year"}} selected{{end}}>{{t "reports.gran.year"}}</option>
      </select>
    </div>
    {{end}}

    {{if .ShowCurrency}}
    <div class="report-field">
      <label for="rp-ccy">{{t "reports.params.currency"}}</label>
      <select id="rp-ccy" name="currency">
        {{- if .CurrencyNative}}
        <option value=""{{if eq .Currency ""}} selected{{end}}>{{t "reports.currency.native"}}</option>
        {{- end}}
        {{- range .Currencies}}
        <option value="{{.Code}}"{{if .Selected}} selected{{end}}>{{.Code}}</option>
        {{- end}}
      </select>
    </div>
    {{end}}

    {{if .ShowDetail}}
    <div class="report-field">
      <label for="rp-detail">{{t "reports.params.detail"}}</label>
      <select id="rp-detail" name="detail" class="report-detail-select">
        <option value=""{{if ne .Detail "currency"}} selected{{end}}>{{t "reports.detail.converted"}}</option>
        <option value="currency"{{if eq .Detail "currency"}} selected{{end}}>{{t "reports.detail.currency"}}</option>
      </select>
    </div>
    {{end}}

    {{if .ShowAccount}}
    <div class="report-field">
      <label for="rp-account">{{t "reports.params.account"}}</label>
      {{/* p28.2: fuzzy account combobox (combo-input) with the dotted hierarchy in
           data-path so "c.boa" ranks "Cash.BOA". */}}
      <select id="rp-account" name="account" class="report-account-select combo-input">
        <option value="0"{{if eq .Account 0}} selected{{end}}>{{t "reports.account.choose"}}</option>
        {{- range .Accounts}}
        <option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $.Account}} selected{{end}}>{{.Path}}</option>
        {{- end}}
      </select>
    </div>
    {{end}}

    {{if .ShowFund}}
    <div class="report-field">
      <label for="rp-fund">{{t "reports.params.fund"}}</label>
      <select id="rp-fund" name="fund" class="report-fund-select">
        <option value="0"{{if eq .Fund 0}} selected{{end}}>{{t "reports.fund_activity.all_funds"}}</option>
        {{- range .Funds}}
        <option value="{{.ID}}"{{if eq .ID $.Fund}} selected{{end}}>{{.Name}}</option>
        {{- end}}
      </select>
    </div>
    {{end}}

    {{if .ShowProgram}}
    <div class="report-field">
      <label for="rp-program">{{t "reports.params.program"}}</label>
      {{/* p29.13: fuzzy program combobox (combo-input) with the dotted hierarchy in
           data-path so a query ranks by the program tree, like the account picker. */}}
      <select id="rp-program" name="program" class="report-program-select combo-input">
        <option value="0"{{if eq .Program 0}} selected{{end}}>{{t "reports.program_statement.all_programs"}}</option>
        {{- range .Programs}}
        <option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $.Program}} selected{{end}}>{{.Name}}</option>
        {{- end}}
      </select>
    </div>
    {{end}}

    {{if .ShowRecon}}
    <div class="report-field">
      <label for="rp-recon">{{t "reports.params.reconciliation"}}</label>
      <select id="rp-recon" name="reconciliation" class="report-recon-select">
        <option value="0"{{if eq .Recon 0}} selected{{end}}>{{t "reports.reconciliation_statement.choose"}}</option>
        {{- range .Recons}}
        <option value="{{.ID}}"{{if eq .ID $.Recon}} selected{{end}}>{{.Label}}</option>
        {{- end}}
      </select>
    </div>
    {{end}}

    {{if .ShowBudget}}
    <div class="report-field">
      <label for="rp-budget">{{t "reports.params.budget"}}</label>
      <select id="rp-budget" name="budget" class="report-budget-select">
        <option value="0"{{if eq .Budget 0}} selected{{end}}>{{t "reports.budget.choose"}}</option>
        {{- range .Budgets}}
        <option value="{{.ID}}"{{if eq .ID $.Budget}} selected{{end}}>{{.Label}}</option>
        {{- end}}
      </select>
    </div>
    {{end}}

    {{/* No-JS fallback: without htmx the change-trigger can't fire, so keep a submit
         (parsed as DOM only when JS is OFF). With JS the form auto-applies on change. */}}
    <noscript><button type="submit" class="btn btn-primary report-run">{{t "reports.params.run"}}</button></noscript>
    {{/* p28.30: a subtle non-disruptive "updating…" cue. htmx adds .htmx-request to
         this <form> for the duration of the filter GET; the .htmx-indicator span is
         hidden by default (htmx's own indicator styles are disabled via htmx-config,
         so the app.css rules own this) and fades in only while the request is in
         flight. It sits in the subnav, never touches #report-results, so the results
         don't reflow. CSP-safe: no inline style/script. */}}
    <span class="htmx-indicator report-updating" aria-hidden="true">{{t "common.updating"}}</span>
  </fieldset>
</form>
{{- end}}

{{/* p26.90: the report RESULTS FRAGMENT — the CSV export link + (for tree reports) the
     collapse/expand controls + the report table, wrapped in a stable #report-results
     div. A filter change (the subnav form's hx-get, hx-target #report-results) swaps ONLY
     this region; the treetable.js <script> stays on the PAGE (a script injected via an
     htmx innerHTML swap does not execute) and re-wires on htmx:afterSwap. The CSV link
     lives INSIDE the fragment so its href (recomputed from the current filter state in the
     handler) refreshes on every swap — a stale export href is impossible. Dot is the
     reportPageModel (so $.Tree here, not $.Page.Tree). Wrapping the table in a div is
     chrome-only: the golden renders the Table, not this shell. */ -}}
{{define "report-results" -}}
{{- with .}}
<div id="report-results">
  {{/* p26.95: a report-LEVEL error (currently: a required exchange rate is missing
       for the chosen target currency) renders inline here INSTEAD of the table/CSV.
       The handler returns HTTP 200 with .Error set so htmx swaps this fragment on an
       apply-on-change filter, rather than leaving a silent no-op from an un-swapped
       5xx. */}}
  {{if .Error}}
  <p class="report-error" role="alert">{{.Error}}</p>
  {{else}}
  <p class="report-export">
    <a href="{{.CSVHref}}" class="report-csv-link" download>{{t "reports.export.csv"}}</a>
  </p>

  {{/* p26.26: reports presenting a NESTED account hierarchy (trial balance, balance
       sheet, income statement, functional expenses) reuse the p26.25 collapse/expand
       tree control. The controls carry `hidden` (no-JS shows the full tree with inert
       hidden buttons); treetable.js reveals + wires them. They live INSIDE #report-results
       so a filter swap re-renders controls + table together (no stale references).
       Non-tree reports skip this block and emit no data-depth, so their tables render
       byte-identically. */}}
  {{if .Tree}}
  <div class="report-controls tree-controls">
    <button type="button" class="btn btn-ghost tree-collapse-all" hidden>{{t "tree.collapse_all"}}</button>
    <button type="button" class="btn btn-ghost tree-expand-level" hidden>{{t "tree.expand_level"}}</button>
    <button type="button" class="btn btn-ghost tree-expand-all" hidden>{{t "tree.expand_all"}}</button>
  </div>
  {{end}}

  {{/* p26.54: the table scrolls inside .report-scroll with STICKY headers -- the top
       header row and the left (first) column stay visible while a wide/tall matrix (e.g.
       the program statement) scrolls. Scoped to @media screen so print/PDF/CSV are
       unaffected. Wrapping the table does not change the golden (the golden renders the
       Table, not this shell) nor the treetable controls (findControls falls back to the
       page-level .tree-controls). */}}
  <div class="report-scroll">
  <table class="report-table{{if .Tree}} tree-table{{end}}">
    <thead>
      <tr>
        {{- range .Table.Columns}}
        <th{{if .Right}} class="amount"{{end}}>{{.Header}}</th>
        {{- end}}
      </tr>
    </thead>
    <tbody>
      {{- range .Table.Rows}}
      <tr class="report-row report-indent-{{.Indent}}{{if .Subtotal}} report-subtotal{{end}}{{if .Total}} report-total{{end}}{{if .Warning}} report-warning{{end}}"{{if $.Tree}} data-depth="{{.Indent}}"{{end}}{{if .Warning}} role="alert"{{end}}>
        {{- range .Cells}}
        <td{{if .Right}} class="amount"{{end}}>{{if .Href}}<a class="report-drill-link" href="{{.Href}}">{{.Text}}</a>{{else}}{{.Text}}{{end}}</td>
        {{- end}}
      </tr>
      {{- else}}
      <tr class="report-empty"><td colspan="{{len .Table.Columns}}">{{t "reports.empty"}}</td></tr>
      {{- end}}
    </tbody>
  </table>
  </div>
  {{end}}
</div>
{{- end}}
{{- end}}

{{define "report.tmpl" -}}
{{template "shell-open" (shellTitle . .Page.Title)}}
  {{- with .Page}}
  <h1>{{.Title}}</h1>

  {{/* p26.86: EVERY report renders its filter form in the SECOND-LEVEL nav bar
       (base.tmpl's SubNavControls="report" case). None inline.
       p26.90: the CSV link + tree-controls + table now live in the #report-results
       fragment a filter change swaps. */}}
  {{template "report-results" .}}

  {{if .Tree}}
  {{/* p26.26: the reusable tree module (p26.25). Loaded on the PAGE (a <script> injected
       via an htmx innerHTML swap would not execute); self-inits on DOMContentLoaded and
       re-runs on htmx:afterSwap when a filter change replaces #report-results. It
       enhances every table.tree-table, looking up the sibling .tree-controls container. */}}
  <script type="module" src="{{asset "treetable.js"}}"></script>
  {{end}}
  {{- end}}
{{template "shell-close" .}}
{{- end}}
