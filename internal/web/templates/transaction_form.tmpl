{{/*
  p12.2 transaction editor (/transactions/new, /transactions/{id}/edit). A shell page
  whose <main> holds the editor grid. The FORM REGION is a single-sourced partial
  ("transaction-form") so the full page and a 422 re-render share ONE markup source
  -- input ids stay stable across the swap (anti-jank / trap 4), with no duplication
  (the p10.3 form-error convention, extended with a per-ROW error slot and a totals
  bar error slot for trap 5).

  Every string via {{t}} (rule 9); dates/amounts through the money formatters
  (rule 10); account/fund/program/payee names are stored proper nouns rendered
  verbatim; NO inline script (rule 12) -- the grid behavior lives in external ES
  modules loaded via {{asset}}.

  Amount entry (trap 3): the SIGNED value posts in the hidden `amount_i` field (works
  with no JS in signed mode). In DR/CR display the twin `dr_i`/`cr_i` text inputs are
  a JS convenience that normalizes into `amount_i` before submit -- ONE mapping site,
  client-side. The server is mode-agnostic on input.

  Stable ids (trap 4): every input id is keyed to the row index (txn-account-<i>,
  txn-amount-<i>, ...), the SAME key that carries the split-id round-trip (the hidden
  split_id_<i>, trap 1).
*/ -}}

{{/* txn-row: one editable split row. Data is a txnRowModel; $ is the page model (for
     the option lists and the display mode). The row's data-row carries its index for
     the JS grid; data-row-error marks a row the server flagged (trap 5). */ -}}
{{define "txn-row" -}}
{{- with .Row -}}
<tr class="txn-row" data-row="{{.Index}}"{{if .ErrorKey}} data-row-error="{{.Index}}"{{end}}>
  {{/* Hidden split id round-trip (trap 1): the existing split's id, or empty for a
       new row. Keyed to the row index (trap 4). */}}
  <input type="hidden" name="split_id_{{.Index}}" id="txn-splitid-{{.Index}}" value="{{.SplitID}}">

  <td class="txn-cell txn-account-cell">
    <select name="account_{{.Index}}" id="txn-account-{{.Index}}" class="txn-account combo-input">
      <option value="0">{{t "txn.account.choose"}}</option>
      {{range $.Page.Accounts}}<option data-account-option value="{{.ID}}"
        data-type="{{.Type}}" data-default-program="{{.DefaultProgram}}"
        data-default-class="{{.DefaultClass}}" data-subsidiaries="{{.SubsCSV}}"
        {{if eq .ID $.Row.Account}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </td>

  {{if $.Page.DisplayDRCR}}
  {{/* DR/CR twin columns (display mode). The JS normalizes these into amount_i. */}}
  <td class="txn-cell txn-amount-cell">
    <input type="text" name="dr_{{.Index}}" id="txn-dr-{{.Index}}" class="txn-dr amount" value="{{.AmountDR}}" inputmode="decimal" placeholder="{{t "txn.amount.debit"}}">
  </td>
  <td class="txn-cell txn-amount-cell">
    <input type="text" name="cr_{{.Index}}" id="txn-cr-{{.Index}}" class="txn-cr amount" value="{{.AmountCR}}" inputmode="decimal" placeholder="{{t "txn.amount.credit"}}">
  </td>
  {{else}}
  {{/* Signed single column (works with no JS). */}}
  <td class="txn-cell txn-amount-cell">
    <input type="text" name="amount_{{.Index}}" id="txn-amount-{{.Index}}" class="txn-amount amount" value="{{.Amount}}" inputmode="decimal" placeholder="{{t "txn.amount.signed"}}">
  </td>
  {{end}}
  {{/* In DR/CR mode the signed field is still present (hidden) so submit posts it. In
       signed mode the visible input above IS amount_i, so no duplicate. */}}
  {{if $.Page.DisplayDRCR}}<input type="hidden" name="amount_{{.Index}}" id="txn-amount-{{.Index}}" value="{{.Amount}}">{{end}}

  <td class="txn-cell txn-fund-cell">
    <select name="fund_{{.Index}}" id="txn-fund-{{.Index}}" class="txn-fund">
      <option value="0">{{t "txn.fund.unrestricted"}}</option>
      {{range $.Page.Funds}}<option value="{{.ID}}"{{if eq .ID $.Row.Fund}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </td>

  <td class="txn-cell txn-program-cell">
    {{/* Program select -- shown by the JS only on R/E rows (Appendix C); rendered
         always so ids stay stable, gated visually by the client. */}}
    <select name="program_{{.Index}}" id="txn-program-{{.Index}}" class="txn-program">
      {{range $.Page.Programs}}<option value="{{.ID}}"{{if eq .ID $.Row.Program}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </td>

  <td class="txn-cell txn-class-cell">
    {{/* Functional class -- shown by the JS only on expense rows; P/M/F. */}}
    <select name="class_{{.Index}}" id="txn-class-{{.Index}}" class="txn-class">
      <option value="">{{t "txn.class.none"}}</option>
      {{range $.Page.Classes}}<option value="{{.}}"{{if eq . $.Row.Class}} selected{{end}}>{{t (printf "txn.class.%s" .)}}</option>
      {{end}}
    </select>
  </td>

  <td class="txn-cell txn-memo-cell">
    <input type="text" name="memo_{{.Index}}" id="txn-memo-{{.Index}}" class="txn-memo" value="{{.Memo}}">
  </td>

  {{if .ErrorKey}}<td class="txn-cell txn-row-error"><span class="field-error" role="alert">{{t .ErrorKey}}</span></td>{{else}}<td class="txn-cell txn-row-error"></td>{{end}}
</tr>
{{- end}}
{{- end}}

{{/* transaction-form: the single-sourced form region. Rendered inside the full page
     AND written alone at 422 on a validation error (the p10.3 convention). The model
     is a shellPage whose .Page is the txnEditorModel. */ -}}
{{define "transaction-form" -}}
{{- with .Page -}}
<form id="txn-form" class="txn-editor" method="post"
      action="{{if .IsEdit}}/transactions/{{.TxnID}}{{else}}/transactions{{end}}"
      hx-post="{{if .IsEdit}}/transactions/{{.TxnID}}{{else}}/transactions{{end}}"
      hx-target="#txn-form" hx-swap="outerHTML"
      data-date-format="{{.DateFormat}}"
      data-root-program="{{.RootProgram}}"
      data-drcr="{{if .DisplayDRCR}}1{{else}}0{{end}}">

  <div class="txn-header">
    <div class="txn-field">
      <label for="txn-subsidiary">{{t "txn.subsidiary"}}</label>
      <select name="subsidiary" id="txn-subsidiary" class="txn-subsidiary"
              hx-get="{{if .IsEdit}}/transactions/{{.TxnID}}/edit{{else}}/transactions/new{{end}}"
              hx-trigger="change" hx-target="#txn-form" hx-swap="outerHTML"
              hx-include="closest form" name-note="re-filters accounts + funds server-side (no-JS fallback)">
        {{range .Subsidiaries}}<option value="{{.ID}}"{{if eq .ID $.Page.Subsidiary}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </div>
    <div class="txn-field">
      <label for="txn-date">{{t "txn.date"}}</label>
      <input type="text" name="date" id="txn-date" class="txn-date" value="{{.Date}}"
             placeholder="{{t "txn.date_hint"}}"
             {{if eq $.Page.FirstErrorRow -2}}autofocus{{end}}>
    </div>
    <div class="txn-field">
      <label for="txn-payee">{{t "txn.payee"}}</label>
      <select name="payee" id="txn-payee" class="txn-payee combo-input">
        <option value="0">{{t "txn.payee_none"}}</option>
        {{range .Payees}}<option value="{{.ID}}"{{if eq .ID $.Page.Payee}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </div>
    <div class="txn-field">
      <label for="txn-memo">{{t "txn.memo"}}</label>
      <input type="text" name="memo" id="txn-memo" class="txn-memo-header" value="{{.Memo}}">
    </div>
    <input type="hidden" name="currency" value="{{.Currency}}">
    <div class="txn-field txn-apply-fund">
      <label for="txn-apply-fund">{{t "txn.fund.apply_all"}}</label>
      <select id="txn-apply-fund" class="txn-apply-fund-select">
        <option value="">{{t "txn.fund.unrestricted"}}</option>
        {{range .Funds}}<option value="{{.ID}}">{{.Name}}</option>
        {{end}}
      </select>
      <button type="button" id="txn-apply-fund-btn" class="btn btn-ghost">{{t "txn.fund.apply_all_btn"}}</button>
    </div>
  </div>

  <table class="txn-grid">
    <thead>
      <tr>
        <th>{{t "txn.col.account"}}</th>
        {{if .DisplayDRCR}}<th>{{t "txn.col.debit"}}</th><th>{{t "txn.col.credit"}}</th>{{else}}<th>{{t "txn.col.amount"}}</th>{{end}}
        <th>{{t "txn.col.fund"}}</th>
        <th>{{t "txn.col.program"}}</th>
        <th>{{t "txn.col.class"}}</th>
        <th>{{t "txn.col.memo"}}</th>
        <th>{{t "txn.col.error"}}</th>
      </tr>
    </thead>
    <tbody id="txn-rows">
      {{range .Rows}}{{template "txn-row" (txnRowCtx $.Page .)}}
      {{end}}
    </tbody>
  </table>
  <input type="hidden" name="rows" id="txn-rows-count" value="{{len .Rows}}">

  <div class="txn-actions">
    <button type="button" id="txn-add-row" class="btn btn-ghost">{{t "txn.add_row"}}</button>
  </div>

  {{/* Sticky totals bar (Appendix C): the live imbalance chips (overall + per fund)
       are populated client-side (display only); the server's authoritative
       imbalance error lands in the totals-error slot (trap 5). */}}
  <div class="txn-totals" id="txn-totals" aria-live="polite">
    <span class="txn-total-chip" id="txn-total-overall"></span>
    <span class="txn-fund-chips" id="txn-fund-chips"></span>
    {{if .TotalsError}}<span class="field-error txn-totals-error" id="txn-totals-error" role="alert"{{if eq $.Page.FirstErrorRow -1}} autofocus{{end}}>{{t .TotalsError}}</span>{{else}}<span class="txn-totals-error" id="txn-totals-error"></span>{{end}}
  </div>

  <div class="txn-submit">
    <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
    <a href="/accounts" class="btn btn-ghost">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
{{- end}}

{{define "transaction_form.tmpl" -}}
{{template "shell-open" (shellTitle . (t (txnTitleKey .Page.IsEdit)))}}
  <h1>{{t (txnTitleKey .Page.IsEdit)}}</h1>
  {{template "transaction-form" .}}
  {{/* The editor's behavior modules (rule 12: external ES modules, no inline script;
       loaded under script-src 'self'). The pure logic (amount/drcr/imbalance/grid)
       lives in txnamount.js/txnfund.js/txngrid.js and is node-tested; txneditor.js is
       the thin DOM glue that wires them to the grid (covered by e2e). */}}
  <script type="module" src="{{asset "txneditor.js"}}"></script>
{{template "shell-close" .}}
{{- end}}
