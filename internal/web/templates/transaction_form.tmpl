{{/*
  p12.2 transaction editor (/transactions/new, /transactions/{id}/edit). A shell page
  whose <main> holds the editor grid. The FORM REGION is a single-sourced partial
  ("transaction-form") so the full page and a 422 re-render share ONE markup source
  -- input ids stay stable across the swap (anti-jank / trap 4), with no duplication
  (the p10.3 form-error convention, extended with a per-ROW error slot and a totals
  bar error slot for trap 5).

  Every string via {{t}} (rule 9); dates/amounts through the money formatters
  (rule 10); account/fund/program/payee names are stored proper nouns rendered
  verbatim; NO inline script (rule 12) -- the grid behavior lives in external ES
  modules loaded via {{asset}}.

  Amount entry (trap 3): the SIGNED value posts in the hidden `amount_i` field (works
  with no JS in signed mode). In DR/CR display the twin `dr_i`/`cr_i` text inputs are
  a JS convenience that normalizes into `amount_i` before submit -- ONE mapping site,
  client-side. The server is mode-agnostic on input.

  Stable ids (trap 4): every input id is keyed to the row index (txn-account-<i>,
  txn-amount-<i>, ...), the SAME key that carries the split-id round-trip (the hidden
  split_id_<i>, trap 1).
*/ -}}

{{/* txn-row: one editable split row. Data is a txnRowModel; $ is the page model (for
     the option lists and the display mode). The row's data-row carries its index for
     the JS grid; data-row-error marks a row the server flagged (trap 5).

     p26.32 two-row layout: each split is ONE <tbody class="txn-row"> holding TWO <tr>:
     row 1 (the wide fields) = description, account, amount; row 2 (packed) = fund,
     program, class, memo, error, delete. Grouping by <tbody> (a table may have many)
     bands both physical <tr> together for the per-split zebra (tbody.txn-row:nth-of-type
     -- self-maintaining across add/delete/reindex) WITHOUT a data-split-index attribute,
     and keeps every id-keyed selector (querySelectorAll('.txn-row'), row.querySelector)
     working because they descend the tbody into both trs. The colspans of the two <tr>
     each sum to 12 so the fixed-layout columns align; row 1's three cells are wider. */ -}}
{{define "txn-row" -}}
{{- with .Row -}}
<tbody class="txn-row" data-row="{{.Index}}"{{if .ErrorKey}} data-row-error="{{.Index}}"{{end}}>
  <tr class="txn-row-main">
    {{/* Hidden split id round-trip (trap 1): the existing split's id, or empty for a
         new row. Keyed to the row index (trap 4). Lives in the first cell of row 1. */}}
    {{/* p26.23: per-split free-text description is the FIRST column (before Account).
         Autocompletes from prior splits' descriptions and, on pick/commit, prefills THIS row
         from the matched split when the row is otherwise empty (descfield.js). The listbox
         lands in the sibling #txn-desc-list-<i> container. */}}
    <td class="txn-cell txn-desc-cell" colspan="5">
      <input type="hidden" name="split_id_{{.Index}}" id="txn-splitid-{{.Index}}" value="{{.SplitID}}">
      <div class="desc-field">
        <input type="text" name="description_{{.Index}}" id="txn-desc-{{.Index}}" class="txn-desc js-descfield"
               value="{{.Description}}" autocomplete="off"
               data-desc-container="txn-desc-list-{{.Index}}"
               data-desc-mode="{{if $.Page.DisplayDRCR}}drcr{{else}}signed{{end}}"
               placeholder="{{t "txn.description_hint"}}">
        <div class="desc-suggest-box" id="txn-desc-list-{{.Index}}" hidden></div>
      </div>
    </td>

    <td class="txn-cell txn-account-cell" colspan="4">
      <select name="account_{{.Index}}" id="txn-account-{{.Index}}" class="txn-account combo-input">
        <option value="0">{{t "txn.account.choose"}}</option>
        {{range $.Page.Accounts}}<option data-account-option value="{{.ID}}"
          data-type="{{.Type}}" data-default-program="{{.DefaultProgram}}"
          data-default-class="{{.DefaultClass}}" data-subsidiaries="{{.SubsCSV}}"
          {{if .Unavailable}}data-unavailable="1" data-path="{{.Path}} {{t "txn.account.unavailable_suffix"}}"{{else}}data-path="{{.Path}}"{{end}}
          {{if eq .ID $.Row.Account}} selected{{end}}>{{.Path}}{{if .Unavailable}} {{t "txn.account.unavailable_suffix"}}{{end}}</option>
        {{end}}
      </select>
    </td>

    {{if $.Page.DisplayDRCR}}
    {{/* DR/CR twin columns (display mode). The JS normalizes these into amount_i. */}}
    <td class="txn-cell txn-amount-cell" colspan="2">
      <input type="text" name="dr_{{.Index}}" id="txn-dr-{{.Index}}" class="txn-dr amount" value="{{.AmountDR}}" inputmode="decimal" placeholder="{{t "txn.amount.debit"}}">
    </td>
    <td class="txn-cell txn-amount-cell" colspan="1">
      <input type="text" name="cr_{{.Index}}" id="txn-cr-{{.Index}}" class="txn-cr amount" value="{{.AmountCR}}" inputmode="decimal" placeholder="{{t "txn.amount.credit"}}">
    </td>
    {{else}}
    {{/* Signed single column (works with no JS). */}}
    <td class="txn-cell txn-amount-cell" colspan="3">
      <input type="text" name="amount_{{.Index}}" id="txn-amount-{{.Index}}" class="txn-amount amount" value="{{.Amount}}" inputmode="decimal" placeholder="{{t "txn.amount.signed"}}">
    </td>
    {{end}}
    {{/* In DR/CR mode the signed field is still present (hidden) so submit posts it. In
         signed mode the visible input above IS amount_i, so no duplicate. */}}
    {{if $.Page.DisplayDRCR}}<input type="hidden" name="amount_{{.Index}}" id="txn-amount-{{.Index}}" value="{{.Amount}}">{{end}}
  </tr>

  <tr class="txn-row-more">
    <td class="txn-cell txn-fund-cell" colspan="3">
      <select name="fund_{{.Index}}" id="txn-fund-{{.Index}}" class="txn-fund combo-input">
        <option value="0">{{t "txn.fund.unrestricted"}}</option>
        {{range $.Page.Funds}}<option value="{{.ID}}"{{if eq .ID $.Row.Fund}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </td>

    <td class="txn-cell txn-program-cell" colspan="3">
      {{/* Program select -- shown by the JS only on R/E rows (Appendix C); rendered
           always so ids stay stable, gated visually by the client. */}}
      <select name="program_{{.Index}}" id="txn-program-{{.Index}}" class="txn-program combo-input">
        {{range $.Page.Programs}}<option value="{{.ID}}"{{if eq .ID $.Row.Program}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
    </td>

    <td class="txn-cell txn-class-cell" colspan="2">
      {{/* Functional class -- shown by the JS only on expense rows; P/M/F. */}}
      <select name="class_{{.Index}}" id="txn-class-{{.Index}}" class="txn-class">
        <option value="">{{t "txn.class.none"}}</option>
        {{range $.Page.Classes}}<option value="{{.}}"{{if eq . $.Row.Class}} selected{{end}}>{{t (printf "txn.class.%s" .)}}</option>
        {{end}}
      </select>
    </td>

    <td class="txn-cell txn-memo-cell" colspan="2">
      <input type="text" name="memo_{{.Index}}" id="txn-memo-{{.Index}}" class="txn-memo" value="{{.Memo}}">
    </td>

    {{/* p26.11: the trailing error cell is a status/message strip, not an editable field --
         drop txn-cell so it loses the borderless-input-in-a-bordered-cell look; the
         .txn-row-error rule styles it as a non-input message cell. */}}
    {{if .ErrorKey}}<td class="txn-row-error" colspan="1"><span class="field-error" role="alert">{{t .ErrorKey}}</span></td>{{else}}<td class="txn-row-error" colspan="1"></td>{{end}}

    {{/* p26.23: a per-row delete control, the LAST cell (after the error column). type="button"
         so it never submits the grid; txneditor.js re-indexes the surviving rows (contiguous
         _i) on click, and deleting the only/last row resets it in place (the grid never drops
         to zero -- exactly one trailing empty row is preserved). */}}
    <td class="txn-delete-cell" colspan="1">
      <button type="button" class="btn btn-ghost txn-delete" aria-label="{{t "common.delete_row"}}" title="{{t "common.delete_row"}}">&times;</button>
    </td>
  </tr>
</tbody>
{{- end}}
{{- end}}

{{/* txn-rows: the split-grid rows fragment. It ranges the SAME single-sourced
     "txn-row" (no fork), so an autofilled/prefilled row is byte-identical to a
     page-rendered one (stable ids / gating / wiring). The model is the txnEditorModel
     directly (the handler renders "txn-rows" with the model as data, not a
     shellPage). */ -}}
{{define "txn-rows" -}}
{{range .Rows}}{{template "txn-row" (txnRowCtx $ .)}}
{{end}}
{{- end}}

{{/* desc-suggest: the p26.18 per-split description autocomplete fragment. A list of
     ranked DISTINCT descriptions (GET /descriptions/suggest?q=&sub=), most-recently
     -used first, sub-preferred. Each <li class="desc-suggestion" role="option"
     data-description> carries the full description on data-description (the visible
     text mirrors it). Empty/blank q -> no <li> children (an empty listbox). The 4b
     UI step targets this from BOTH the txn grid and the expense grid, so it is
     self-contained (no editor-model chrome). Model: descSuggestModel (.Suggestions
     []string). Mirrors the old payee-suggest shape so the client glue is familiar. */ -}}
{{define "desc-suggest" -}}
<ul class="desc-suggestions" role="listbox">{{range .Suggestions}}
<li class="desc-suggestion" role="option" data-description="{{.}}">{{.}}</li>{{end}}
</ul>
{{- end}}

{{/* desc-prefill: the p26.18 per-ROW prefill fragment (GET /descriptions/prefill?q=
     &sub=). A single element carrying the most-recent matching split's fields as
     data-* attributes: account, amount (signed, user's number format, the matched
     split's currency), fund, program, functional class, memo. The 4b UI step reads
     these and fills the row's inputs when the row is otherwise empty. No match ->
     the SAME element with NO data-* attributes (data-found="0"), which the client
     detects as "nothing to prefill". Model: descPrefillModel. account/fund/program
     ids may be inactive / out-of-sub -- returned regardless (the editor's p26.10
     injection + save guard handle display/validation). */ -}}
{{define "desc-prefill" -}}
{{if .Found -}}
<div id="desc-prefill" data-found="1" data-account="{{.AccountID}}" data-amount="{{.AmountInput}}" data-fund="{{.FundID}}" data-program="{{.ProgramID}}" data-class="{{.Class}}" data-memo="{{.Memo}}"></div>
{{- else -}}
<div id="desc-prefill" data-found="0"></div>
{{- end}}
{{- end}}

{{/* transaction-form: the single-sourced form region. Rendered inside the full page
     AND written alone at 422 on a validation error (the p10.3 convention). The model
     is a shellPage whose .Page is the txnEditorModel. */ -}}
{{define "transaction-form" -}}
{{- with .Page -}}
<form id="txn-form" class="txn-editor" method="post"
      action="{{if .ImportRowID}}/import/rows/{{.ImportRowID}}/post{{else if .ExpenseReportID}}/expenses/review/post/{{.ExpenseReportID}}{{else if .IsEdit}}/transactions/{{.TxnID}}{{else}}/transactions{{end}}"
      hx-post="{{if .ImportRowID}}/import/rows/{{.ImportRowID}}/post{{else if .ExpenseReportID}}/expenses/review/post/{{.ExpenseReportID}}{{else if .IsEdit}}/transactions/{{.TxnID}}{{else}}/transactions{{end}}"
      hx-target="#txn-form" hx-swap="outerHTML"
      data-date-format="{{.DateFormat}}"
      data-root-program="{{.RootProgram}}"
      data-user-program="{{.UserProgram}}"
      data-account-missing-msg="{{t "error.txn.account_missing"}}"
      data-drcr="{{if .DisplayDRCR}}1{{else}}0{{end}}">

  <div class="txn-header">
    <div class="txn-field">
      <label for="txn-subsidiary">{{t "txn.subsidiary"}}</label>
      {{if or .ImportRowID .ExpenseReportID}}
      {{/* p17.3 edit&post / p20.3 review&post: the source row/report binds ONE
           subsidiary, so it is LOCKED. A disabled select does not POST, so a hidden
           input carries the id; the sub-change re-filter hx-get is suppressed (the sub
           cannot change here). */}}
      <select name="subsidiary_locked" id="txn-subsidiary" class="txn-subsidiary" disabled
              aria-describedby="txn-subsidiary-locked">
        {{range .Subsidiaries}}<option value="{{.ID}}"{{if eq .ID $.Page.Subsidiary}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
      <input type="hidden" name="subsidiary" value="{{.Subsidiary}}">
      <span id="txn-subsidiary-locked" class="hint txn-subsidiary-locked">{{if .ExpenseReportID}}{{t "expreview.sub_locked"}}{{else}}{{t "import.posthdr_sub_locked"}}{{end}}</span>
      {{else}}
      <select name="subsidiary" id="txn-subsidiary" class="txn-subsidiary"
              hx-get="{{if .IsEdit}}/transactions/{{.TxnID}}/edit{{else}}/transactions/new{{end}}"
              hx-trigger="change" hx-target="#txn-form" hx-swap="outerHTML"
              hx-include="closest form" name-note="re-filters accounts + funds server-side (no-JS fallback)">
        {{range .Subsidiaries}}<option value="{{.ID}}"{{if eq .ID $.Page.Subsidiary}} selected{{end}}>{{.Name}}</option>
        {{end}}
      </select>
      {{end}}
    </div>
    <div class="txn-field">
      <label for="txn-date">{{t "txn.date"}}</label>
      <input type="text" name="date" id="txn-date" class="txn-date js-datefield" value="{{.Date}}"
             placeholder="{{t "txn.date_hint"}}"
             {{if eq $.Page.FirstErrorRow -2}}autofocus{{end}}>
    </div>
    {{/* The per-transaction payee header was removed (p26.19) -- the per-split free-text
         description (in each grid row) replaces it, autocompleting + prefilling per row.
         The payee data/columns/routes were physically removed in p26.20. */}}
    {{/* p26.23: with the payee and apply-fund controls both gone, the header memo grows to
         fill the freed horizontal space (the txn-field-grow modifier flex-grows this field). */}}
    <div class="txn-field txn-field-grow">
      <label for="txn-memo">{{t "txn.memo"}}</label>
      <input type="text" name="memo" id="txn-memo" class="txn-memo-header" value="{{.Memo}}">
    </div>
    <input type="hidden" name="currency" value="{{.Currency}}">
    {{/* p26.33: the Cancel origin (the register the user came from). Hidden so it posts
         with the form (survives a 422) and rides the subsidiary re-filter via hx-include.
         Server-sanitized to a same-site path; empty => Cancel falls back to /accounts. */}}
    <input type="hidden" name="from" id="txn-origin" value="{{.Origin}}">
  </div>

  {{/* p26.32 two-row split layout: each split is its OWN <tbody class="txn-row"> (see
       "txn-row"), so the grid's rows are tbodies, not a single wrapping tbody. The thead
       labels row 1's three wide columns (description / account / amount); row 2's packed
       fields (fund / program / class / memo) are unlabeled -- their inline selects carry
       their own placeholders/values. Colspans on the header cells match row 1's cells so
       the fixed-layout columns align (5 + 4 + 3 = 12). */}}
  <table class="txn-grid txn-grid-2row">
    <thead>
      <tr>
        <th colspan="5">{{t "txn.col.description"}}</th>
        <th colspan="4">{{t "txn.col.account"}}</th>
        {{if .DisplayDRCR}}<th colspan="2">{{t "txn.col.debit"}}</th><th colspan="1">{{t "txn.col.credit"}}</th>{{else}}<th colspan="3">{{t "txn.col.amount"}}</th>{{end}}
      </tr>
    </thead>
    {{range .Rows}}{{template "txn-row" (txnRowCtx $.Page .)}}
    {{end}}
  </table>
  <input type="hidden" name="rows" id="txn-rows-count" value="{{len .Rows}}">
  {{/* p25.2: no "Add row" button — the grid starts with one empty row and the client
       auto-appends a fresh trailing row as soon as the last row is edited; the trailing
       empty row is dropped server-side on submit. */}}

  {{/* Sticky totals bar (Appendix C): the live imbalance chips (overall + per fund)
       are populated client-side (display only); the server's authoritative
       imbalance error lands in the totals-error slot (trap 5). */}}
  <div class="txn-totals" id="txn-totals" aria-live="polite">
    <span class="txn-total-chip" id="txn-total-overall"></span>
    <span class="txn-fund-chips" id="txn-fund-chips"></span>
    {{if .TotalsError}}<span class="field-error txn-totals-error" id="txn-totals-error" role="alert"{{if eq $.Page.FirstErrorRow -1}} autofocus{{end}}>{{t .TotalsError}}</span>{{else}}<span class="txn-totals-error" id="txn-totals-error"></span>{{end}}
  </div>

  {{/* p24.2 transaction-level notes: a longer multiline explanation (distinct from
       the short per-split memos). Full-width below the grid so it never crowds the
       header fields; echoed on the subsidiary re-filter and on a 422. */}}
  <div class="txn-notes-field">
    <label for="txn-notes">{{t "txn.notes"}}</label>
    <textarea name="notes" id="txn-notes" class="txn-notes" rows="2">{{.Notes}}</textarea>
  </div>

  <div class="txn-submit">
    <button type="submit" class="btn btn-primary">{{if .ImportRowID}}{{t "import.posthdr_btn"}}{{else if .ExpenseReportID}}{{t "expreview.post_btn"}}{{else}}{{t "common.save"}}{{end}}</button>
    {{/* p26.33: Cancel returns to the origin register (`from`, sanitized server-side) for a
         normal txn, else /accounts. Import/expense-review keep their dedicated destinations. */}}
    <a href="{{if .ImportRowID}}/import/batches/{{.ImportBatchID}}{{else if .ExpenseReportID}}/expenses/review{{else if .Origin}}{{.Origin}}{{else}}/accounts{{end}}" class="btn btn-ghost">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
{{- end}}

{{define "transaction_form.tmpl" -}}
{{if .Page.ImportRowID}}
{{template "shell-open" (shellTitle . (t "import.posthdr_title"))}}
  <h1>{{t "import.posthdr_title"}}</h1>
  <p class="hint">{{t "import.posthdr_intro"}}</p>
  {{template "transaction-form" .}}
{{else if .Page.ExpenseReportID}}
{{template "shell-open" (shellTitle . (t "expreview.post_title"))}}
  <h1>{{t "expreview.post_title"}}</h1>
  <p class="hint">{{t "expreview.post_intro"}}</p>
  {{template "transaction-form" .}}
  {{/* p26.27: reject-with-reason lives HERE (the review page), a SIBLING of the post
       form -- NOT nested (no nested forms). A plain (no-htmx) POST: a blank reason
       re-renders THIS page at 422 with the reject-reason error; a successful reject
       303-redirects back to the queue. */}}
  {{- with .Page}}
  <section class="expreview-reject" aria-labelledby="expreview-reject-heading">
    <h2 id="expreview-reject-heading" class="expreview-reject-heading">{{t "expreview.reject_heading"}}</h2>
    <form class="expreview-reject-form" method="post" action="/expenses/review/reject/{{.ExpenseReportID}}">
      <label for="expreview-reject-reason" class="expreview-reject-reason-label">{{t "expreview.reject_reason_label"}}</label>
      <input type="text" name="reason" id="expreview-reject-reason" class="expreview-reject-reason"
             placeholder="{{t "expreview.reject_reason_placeholder"}}"
             aria-label="{{t "expreview.reject_reason_label"}}">
      {{if .RejectError}}<span class="field-error expreview-reject-error" role="alert">{{t .RejectError}}</span>{{end}}
      <button type="submit" class="btn btn-ghost expreview-reject-btn">{{t "expreview.reject"}}</button>
    </form>
  </section>
  {{- end}}
{{else}}
{{template "shell-open" (shellTitle . (t (txnTitleKey .Page.IsEdit)))}}
  <h1>{{t (txnTitleKey .Page.IsEdit)}}</h1>
  {{template "transaction-form" .}}
{{end}}
  {{/* The editor's behavior modules (rule 12: external ES modules, no inline script;
       loaded under script-src 'self'). The pure logic (amount/drcr/imbalance/grid)
       lives in txnamount.js/txnfund.js/txngrid.js and is node-tested; txneditor.js is
       the thin DOM glue that wires them to the grid (covered by e2e). */}}
  <script type="module" src="{{asset "txneditor.js"}}"></script>
{{template "shell-close" .}}
{{- end}}
