{{/*
  p11.2 merge-accounts partials. Two named templates share this file:

    - "merge-form": the picker (source leaf + destination leaf). It swaps into
      #account-form (like the create/edit form). hx-post /accounts/merge WITHOUT a
      confirm flag, so a first submit renders the consequences preview. On a store
      typed error the handler re-renders THIS partial at 422 with a localized field
      error (.Errors, the p10.3 convention); autofocus lands on .Errors.FirstInvalid.

    - "merge-preview": the consequences summary + Confirm control. It re-POSTs to
      /accounts/merge with the same src/dst PLUS confirm=1 (a hidden input), so the
      SECOND submit executes the merge. The preview reports the split count that will
      repoint and the reconciliation count (0 until p16), and restates the coverage
      rule as an informational note.

  Both target #account-form / outerHTML. Every string via {{t}} (rule 9); no inline
  script (rule 12).
*/ -}}

{{define "merge-form" -}}
<form id="account-form" class="account-form merge-form"
      hx-post="/accounts/merge" hx-target="#account-form" hx-swap="outerHTML">
  <h2>{{t "merge.title"}}</h2>
  <p class="hint">{{t "merge.intro"}}</p>

  <div class="field">
    <label for="mg-src">{{t "merge.source"}}</label>
    <select id="mg-src" name="src"
      {{- if eq .Errors.FirstInvalid "src"}} autofocus{{end}}>
      <option value="0">{{t "merge.select_placeholder"}}</option>
      {{range .Leaves}}<option value="{{.ID}}"{{if eq .ID $.Src}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "src"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="mg-dst">{{t "merge.destination"}}</label>
    <select id="mg-dst" name="dst"
      {{- if eq .Errors.FirstInvalid "dst"}} autofocus{{end}}>
      <option value="0">{{t "merge.select_placeholder"}}</option>
      {{range .Leaves}}<option value="{{.ID}}"{{if eq .ID $.Dst}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "dst"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <p class="hint">{{t "merge.coverage_note"}}</p>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "merge.review"}}</button>
    <a class="btn btn-ghost" href="/accounts">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}

{{define "merge-preview" -}}
<form id="account-form" class="account-form merge-preview"
      hx-post="/accounts/merge" hx-target="#account-form" hx-swap="outerHTML">
  <h2>{{t "merge.confirm_title"}}</h2>

  <p class="merge-summary">{{t "merge.summary" .SrcName .DstName}}</p>
  <ul class="merge-consequences">
    <li>{{t "merge.consequence.splits" .SplitCount}}</li>
    <li>{{t "merge.consequence.recons" .ReconCount}}</li>
    <li>{{t "merge.consequence.deactivate" .SrcName}}</li>
  </ul>
  <p class="hint">{{t "merge.coverage_note"}}</p>

  <input type="hidden" name="src" value="{{.Src}}">
  <input type="hidden" name="dst" value="{{.Dst}}">
  <input type="hidden" name="confirm" value="1">

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "merge.confirm"}}</button>
    <a class="btn btn-ghost" href="/accounts">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
