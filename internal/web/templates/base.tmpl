{{/*
  p10.2 authenticated shell. base.tmpl defines the reusable chrome as PARTIALS and
  is itself the authenticated LANDING page (GET /{$}).

  Every shell page provides:
    - <html lang="{resolved locale}">           (D14)
    - data-theme="{cookie theme}" set SERVER-SIDE (no flash)
    - semantic landmarks: <header><nav><main><footer>
    - a flash message region (aria-live; populated by later phases)
    - the stylesheet via {{asset "app.css"}}
    - a perm-gated, data-driven nav
    - EVERY visible string via {{t "key"}} (rule 9)

  html/template shares ONE parse set, so a page cannot override a shared "content"
  block (a redefinition error at parse). Instead the frame is split into a
  shell-open / shell-close partial pair; each shell page (base.tmpl,
  settings.tmpl, styleguide.tmpl) is a self-contained top-level template that
  emits shell-open, its own <main> content, then shell-close. The model is a
  shellPage: .Shell carries the chrome (Lang/Theme/Nav/Version), .Page the page
  body's data.

  No inline <script> or style attributes -- strict CSP (rule 12); the theme
  toggle is a plain <form> POST, JS-free.
*/ -}}

{{/* brand-icon: the "Open Ledger & Star" mark, inline so it is themeable from
     app.css (an external <img> SVG can't see page CSS, and a <style> inside the
     SVG would violate style-src 'self'). The shapes carry classes only; their
     colors (blue book, gold star) come from app.css tokens, which are
     light-dark() pairs — so the mark adapts to light/dark with no JS and no
     inline style (rule 12). aria-hidden: the accessible name lives on the link. */ -}}
{{define "brand-icon" -}}
<svg class="brand-icon" viewBox="0 0 64 64" aria-hidden="true" focusable="false">
  <g class="logo-book" fill="none" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M32 22 C 25 17, 16 17, 10 19 L 10 50 C 16 48, 25 48, 32 52"/>
    <path d="M32 22 C 39 17, 48 17, 54 19 L 54 50 C 48 48, 39 48, 32 52"/>
    <line x1="32" y1="22" x2="32" y2="52"/>
    <line x1="16" y1="27" x2="27" y2="27"/>
    <line x1="16" y1="34" x2="27" y2="34"/>
    <line x1="16" y1="41" x2="27" y2="41"/>
  </g>
  <path class="logo-star" d="M32 3 l2.1 4.3 4.7 .7 -3.4 3.3 .8 4.7 -4.2 -2.2 -4.2 2.2 .8 -4.7 -3.4 -3.3 4.7 -.7z"/>
</svg>
{{- end}}

{{define "shell-nav" -}}
<header class="app-header">
  <a class="app-brand" href="/" aria-label="{{t "app.name"}}">
    {{template "brand-icon" .}}
    <span class="app-brand-name">{{t "app.name"}}</span>
  </a>
  {{/* p10.3: hx-boost on the TOP-LEVEL nav ONLY (progressive enhancement) — the
       <a href> links still work as full-page navigations without JS; with htmx
       loaded, boosting turns them into targeted body swaps for a snappier feel.
       Scoped to this <nav> alone: forms (logout, theme) and page content are NOT
       boosted (task: nav only). */}}
  <nav class="app-nav" aria-label="{{t "nav.label"}}" hx-boost="true">
    <ul>
      {{range .Shell.Nav}}<li><a href="{{.Href}}"{{if .Current}} aria-current="page"{{end}}>{{.Label}}</a></li>
      {{end}}
    </ul>
  </nav>
  {{/* p26.48: "New transaction" is pulled OUT of the nav loop and rendered as a
       DISTINCT, right-aligned primary button (perm-gated: nil when the user lacks
       TxnWrite). It is hx-boosted like the nav so the click swaps <body>; renderEditor
       returns the full shell for a boosted request (p26.35), so the editor JS re-inits.
       .app-newtxn margin-left:auto pins it (and the logout) to the right. */ -}}
  {{if .Shell.NewTxn}}
  <a class="btn btn-primary app-newtxn" href="{{.Shell.NewTxn.Href}}" hx-boost="true">{{.Shell.NewTxn.Label}}</a>
  {{end}}
  <form class="app-logout" method="post" action="/logout">
    <button type="submit" class="btn btn-ghost">{{t "auth.sign_out"}}</button>
  </form>
</header>
{{/* p23.5 second row: the current section's sub-navigation. Rendered only when the
     section has sub-nav (nil = no bar); this row is also where per-page filters and
     search land in later work. hx-boosted like the top nav. */ -}}
{{if or .Shell.SubNav .Shell.SubNavControls}}
<nav class="app-subnav" aria-label="{{t "nav.section_label"}}">
  {{if .Shell.SubNav}}
  <ul class="app-subnav-links" hx-boost="true">
    {{range .Shell.SubNav}}<li><a href="{{.Href}}"{{if .Current}} aria-current="page"{{end}}>{{.Label}}</a></li>
    {{end}}
  </ul>
  {{end}}
  {{/* p23.10 page-specific controls (filters/buttons a page moved into the second-
       level menu). Rendered by CONSTANT template names guarded on SubNavControls —
       no dynamic dispatch, no re-entrancy. .Page is the page model. */}}
  {{if .Shell.SubNavControls}}
  <div class="app-subnav-controls">
    {{if eq .Shell.SubNavControls "accounts"}}{{template "accounts-controls" .Page}}{{end}}
    {{if eq .Shell.SubNavControls "funds"}}{{template "funds-controls" .Page}}{{end}}
    {{if eq .Shell.SubNavControls "programs"}}{{template "programs-controls" .Page}}{{end}}
    {{if eq .Shell.SubNavControls "subsidiaries"}}{{template "subsidiaries-controls" .Page}}{{end}}
    {{if eq .Shell.SubNavControls "register"}}{{template "register-controls" .Page}}{{end}}
    {{if eq .Shell.SubNavControls "budgets"}}{{template "budgets-controls" .Page}}{{end}}
    {{/* p26.76: a report's filter form in the second-level nav bar (the .Page is a
         reportPageModel; the shared partial takes its .Params paramsForm). */}}
    {{if eq .Shell.SubNavControls "report"}}{{template "report-filters" .Page.Params}}{{end}}
  </div>
  {{end}}
</nav>
{{end}}
{{- end}}

{{/* shell-open opens the document through the start of <main>. The caller passes
     a shellPage plus a localized .Title via a small wrapper (see the page
     templates), so the head title is a real catalog string. */ -}}
{{define "shell-open" -}}
<!DOCTYPE html>
<html lang="{{.Shell.Lang}}" data-theme="{{.Shell.Theme}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}} — {{t "app.name"}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml">
  <link rel="stylesheet" href="{{asset "app.css"}}">
  {{/* p10.3 htmx config, set BEFORE htmx loads (CSP-safe: a meta, never inline
       script — rule 12). Two things the form-error convention needs:
       - responseHandling: by default htmx 2.x does NOT swap 4xx/5xx (it fires
         htmx:responseError). The form-error convention returns 422 and MUST swap
         the form-region partial, so 422 is added as swap:true (first match wins,
         so it precedes the [45].. error rule). 2xx/3xx keep the default swap.
       - includeIndicatorStyles:false: htmx otherwise injects an inline <style> for
         .htmx-indicator on load, which the strict style-src 'self' CSP would block
         (a console error on every page). Any indicator CSS lives in app.css. */}}
  <meta name="htmx-config" content='{"includeIndicatorStyles":false,"responseHandling":[{"code":"204","swap":false},{"code":"422","swap":true},{"code":"[23]..","swap":true},{"code":"[45]..","swap":false,"error":true}]}'>
  {{/* Vendored, pinned htmx (2.0.4) served locally under script-src 'self' via the
       p10.1 asset pipeline — never a CDN at runtime (rule 12; see VENDOR.md).
       `defer` so it runs after the DOM parses; htmx processes hx-* on load. */}}
  <script src="{{asset "htmx.min.js"}}" defer></script>
  {{/* p10.3 form-focus glue: after an htmx swap, move focus to the first
       [autofocus] field of the swapped region (browsers don't fire autofocus on
       inserted nodes). A small hand-written ES module (rule 12), external so it
       loads under script-src 'self' — no inline handler; unit-tested via node
       --test (formfocus.test.js). */}}
  <script type="module" src="{{asset "formfocus.js"}}"></script>
  {{/* p23.4 global date-field enhancer: enhances every input.js-datefield with the
       flexible parse/format, GnuCash shortcuts, and a hand-written calendar popover
       (rule 10: never input[type=date]; rule 12: external module, no inline script).
       Loaded shell-wide so it applies on every page with a date input. */}}
  <script type="module" src="{{asset "datefield.js"}}"></script>
</head>
{{/* data-* feed datefield.js: the per-user date format and the localized calendar
     labels (rule 9: the strings originate in the i18n catalog, rendered here). */ -}}
<body data-date-format="{{.Shell.DateFormat}}"
      data-cal-months="{{t "cal.months"}}" data-cal-weekdays="{{t "cal.weekdays"}}"
      data-cal-pick="{{t "cal.pick"}}" data-cal-prev="{{t "cal.prev_month"}}" data-cal-next="{{t "cal.next_month"}}">
  <a class="skip-link" href="#main">{{t "common.skip_to_content"}}</a>
  {{template "shell-nav" .}}
  <div class="flash" role="status" aria-live="polite"></div>
  <main id="main" class="app-main{{if .Shell.Wide}} app-main-wide{{end}}">
{{- end}}

{{define "shell-close" -}}
  </main>
  <footer class="app-footer">
    <small>{{t "app.name"}} · {{t "footer.version" .Shell.Version}}</small>
  </footer>
</body>
</html>
{{- end}}
