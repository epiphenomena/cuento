{{/*
  p13.1 My settings (GET /settings, AnyUser). ONE personal-preferences page: UI
  language, money/date display (date format, number format, display mode signed vs
  DR/CR, negative style), theme, and the (optional) default subsidiary for new
  transactions. A user edits THEIR OWN settings only.

  A plain full-page form POST to /settings (NOT an htmx partial swap -- this page is
  the whole settings document; on save it 303-redirects back to GET /settings so the
  new locale/theme render on the fresh load). Every input is a fixed <select>, so a
  normal user cannot submit an invalid value; a crafted invalid POST re-renders this
  whole page at 422 with the field error + autofocus on the first invalid control.
  .Page is a settingsForm. Every string via {{t}} (rule 9); no inline script/style
  (rule 12).
*/ -}}
{{define "settings.tmpl" -}}
{{template "shell-open" (shellTitle . (t "settings.title"))}}
  {{- with .Page}}
  <h1>{{t "settings.title"}}</h1>
  <p class="hint">{{t "settings.intro"}}</p>

  {{if .Saved}}
  <p class="notice" role="status">{{t "settings.saved"}}</p>
  {{end}}

  {{if .Errors.FirstInvalid}}
  <p class="error" role="alert">{{t "settings.error.invalid"}}</p>
  {{end}}

  {{/* A user's OWN display name (the name reports/expense forms can use). Its own
       small form posting to /settings/display-name -- a free-text field, so it
       carries an inline field-level error (empty / too long) unlike the fixed
       selects below. */}}
  <form method="post" action="/settings/display-name" class="settings-name-form">
    {{if .NameSaved}}
    <p class="notice" role="status">{{t "settings.name.saved"}}</p>
    {{end}}
    <div class="field">
      <label for="setting-name">{{t "settings.name.label"}}</label>
      <input id="setting-name" name="display_name" type="text" value="{{.DisplayName}}"
             autocomplete="name" maxlength="200"
             {{- if .DisplayNameError}} autofocus aria-invalid="true"{{end}}>
      {{if .DisplayNameError}}<p class="error" role="alert">{{t .DisplayNameError}}</p>{{end}}
      <p class="hint">{{t "settings.name.hint"}}</p>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">{{t "settings.name.save"}}</button>
    </div>
  </form>

  <form method="post" action="/settings" class="settings-form">
    <div class="field">
      <label for="setting-locale">{{t "settings.language"}}</label>
      <select id="setting-locale" name="locale"{{if eq .Errors.FirstInvalid "locale"}} autofocus{{end}}>
        {{- range .Langs}}
        <option value="{{.Code}}"{{if .Current}} selected{{end}}>{{.Label}}</option>
        {{- end}}
      </select>
    </div>

    <div class="field">
      <label for="setting-date">{{t "settings.date_format"}}</label>
      <select id="setting-date" name="date_format">
        {{- range .DateFormats}}
        <option value="{{.Value}}"{{if eq .Value $.Page.DateFormat}} selected{{end}}>{{t .LabelKey}}</option>
        {{- end}}
      </select>
    </div>

    <div class="field">
      <label for="setting-number">{{t "settings.number_format"}}</label>
      <select id="setting-number" name="number_format">
        {{- range .NumberFmts}}
        <option value="{{.Value}}"{{if eq .Value $.Page.NumberFormat}} selected{{end}}>{{t .LabelKey}}</option>
        {{- end}}
      </select>
    </div>

    <div class="field">
      <label for="setting-display">{{t "settings.display_mode"}}</label>
      <select id="setting-display" name="display_mode">
        {{- range .DisplayModes}}
        <option value="{{.Value}}"{{if eq .Value $.Page.DisplayMode}} selected{{end}}>{{t .LabelKey}}</option>
        {{- end}}
      </select>
    </div>

    <div class="field">
      <label for="setting-neg">{{t "settings.neg_style"}}</label>
      <select id="setting-neg" name="neg_style">
        {{- range .NegStyles}}
        <option value="{{.Value}}"{{if eq .Value $.Page.NegStyle}} selected{{end}}>{{t .LabelKey}}</option>
        {{- end}}
      </select>
    </div>

    <div class="field">
      <label for="setting-theme">{{t "settings.theme"}}</label>
      <select id="setting-theme" name="theme">
        {{- range .Themes}}
        <option value="{{.Value}}"{{if eq .Value $.Page.Theme}} selected{{end}}>{{t .LabelKey}}</option>
        {{- end}}
      </select>
    </div>

    <div class="field">
      <label for="setting-sub">{{t "settings.default_subsidiary"}}</label>
      <select id="setting-sub" name="default_subsidiary">
        <option value="">{{t "settings.default_subsidiary_none"}}</option>
        {{- range .Subs}}
        <option value="{{.ID}}"{{if eq .ID $.Page.DefaultSub}} selected{{end}}>{{.Name}}</option>
        {{- end}}
      </select>
      <p class="hint">{{t "settings.default_subsidiary_hint"}}</p>
    </div>

    <div class="field">
      <label for="setting-program">{{t "settings.default_program"}}</label>
      {{/* p29.13: fuzzy program combobox (combo-input) with the dotted hierarchy in data-path. */}}
      <select id="setting-program" name="default_program" class="combo-input"{{if eq .Errors.FirstInvalid "default_program"}} autofocus{{end}}>
        <option value="">{{t "settings.default_program_none"}}</option>
        {{- range .Programs}}
        <option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $.Page.DefaultProgram}} selected{{end}}>{{.Name}}</option>
        {{- end}}
      </select>
      <p class="hint">{{t "settings.default_program_hint"}}</p>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
      <a class="btn btn-ghost" href="/">{{t "common.cancel"}}</a>
    </div>
  </form>
  {{- end}}
{{template "shell-close" .}}
{{- end}}
