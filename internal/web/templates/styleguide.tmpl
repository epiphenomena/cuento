{{/*
  p10.2 -dev-only styleguide (GET /styleguide, Public, registered only in -dev).
  A component gallery for visual review of the CSS primitives (buttons, forms,
  alerts) against the token/reset/component layers in app.css. Renders through the
  shell so the chrome (nav, theme, footer) is reviewable too. Every string via
  {{t}} (rule 9) so the gallery is bilingual like the rest of the app.
*/ -}}
{{define "styleguide.tmpl" -}}
{{template "shell-open" (shellTitle . (t "styleguide.title"))}}
  <h1>{{t "styleguide.title"}}</h1>

  <section aria-labelledby="sg-brand">
    <h2 id="sg-brand">{{t "styleguide.brand"}}</h2>
    {{/* The mark + wordmark rendered in BOTH themes on one page: each pane pins
         its own color-scheme so light-dark() resolves per pane (app.css). */}}
    <div class="theme-previews">
      <div class="theme-preview is-light">
        <h3>{{t "theme.light"}}</h3>
        <span class="brand-lockup">{{template "brand-icon" .}}<span class="app-brand-name">{{t "app.name"}}</span></span>
      </div>
      <div class="theme-preview is-dark">
        <h3>{{t "theme.dark"}}</h3>
        <span class="brand-lockup">{{template "brand-icon" .}}<span class="app-brand-name">{{t "app.name"}}</span></span>
      </div>
    </div>
  </section>

  <section aria-labelledby="sg-palette">
    <h2 id="sg-palette">{{t "styleguide.palette"}}</h2>
    <ul class="swatches">
      <li class="swatch"><span class="swatch-chip is-blue"></span><span class="swatch-name">Primary Blue</span><span class="swatch-hex">#0072CE</span></li>
      <li class="swatch"><span class="swatch-chip is-gold"></span><span class="swatch-name">Accent Gold</span><span class="swatch-hex">#FFB81C</span></li>
      <li class="swatch"><span class="swatch-chip is-white"></span><span class="swatch-name">White</span><span class="swatch-hex">#FFFFFF</span></li>
      <li class="swatch"><span class="swatch-chip is-navy"></span><span class="swatch-name">Deep Navy</span><span class="swatch-hex">#0A1A2F</span></li>
    </ul>
  </section>

  <section aria-labelledby="sg-buttons">
    <h2 id="sg-buttons">{{t "styleguide.buttons"}}</h2>
    <p class="cluster">
      <button type="button" class="btn">{{t "common.save"}}</button>
      <button type="button" class="btn btn-primary">{{t "common.save"}}</button>
      <button type="button" class="btn btn-ghost">{{t "common.cancel"}}</button>
    </p>
  </section>

  <section aria-labelledby="sg-forms">
    <h2 id="sg-forms">{{t "styleguide.forms"}}</h2>
    <div class="field">
      <label for="sg-text">{{t "auth.username"}}</label>
      <input id="sg-text" type="text" placeholder="{{t "auth.username"}}">
    </div>
    <div class="field">
      <label for="sg-select">{{t "theme.label"}}</label>
      <select id="sg-select">
        <option>{{t "theme.auto"}}</option>
        <option>{{t "theme.light"}}</option>
        <option>{{t "theme.dark"}}</option>
      </select>
    </div>
  </section>

  <section aria-labelledby="sg-alerts">
    <h2 id="sg-alerts">{{t "styleguide.alerts"}}</h2>
    <p class="alert" role="alert">{{t "auth.invalid"}}</p>
  </section>

  <section aria-labelledby="sg-form-demo">
    <h2 id="sg-form-demo">{{t "styleguide.form_demo"}}</h2>
    {{/* The form region is single-sourced: this same "demo-form" partial is what a
         failed POST re-renders at 422 (and a valid POST at 200), so htmx swaps it
         in place with stable ids. .Page is the demoFormModel. */}}
    {{template "demo-form" .Page}}
  </section>
{{template "shell-close" .}}
{{- end}}
