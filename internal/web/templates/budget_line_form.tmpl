{{/*
  p19.3 budget-line create/edit form partial ("line-form"). SINGLE SOURCE of the form
  region: the budget detail renders the "New line" trigger inside #line-form; GET
  /budgets/{id}/lines/new and .../lines/{lid}/edit swap THIS partial in, and a failed
  POST re-renders it at 422 (stable ids across swaps, Appendix C). The dot is always a
  lineFormModel.

  SUB-SCOPED SELECTORS: the account/fund options are filtered to the chosen
  SUBSIDIARY (accounts = R/E leaves in the sub; funds = ActiveFunds(sub)), exactly
  like the transaction editor (p12.2). Changing the subsidiary re-fetches THIS form
  via hx-get with the chosen `subsidiary`, so the SERVER re-filters the options
  (server is the source of truth for fund scope, D20). The e2e MUST wait for the form
  to settle (`e2e-settled`) before driving the re-rendered selects. Programs are NOT
  sub-scoped (all active, like the txn editor -- DECISIONS p19.3).

  hx-post targets /budgets/{bid}/lines (create) when .ID is 0, else
  /budgets/{bid}/lines/{id} (edit). Field errors come from .Errors (formErrors), i18n
  KEYS via {{t}} (rule 9); amounts entered in the user's number format (rule 10). No
  inline script/style (strict CSP, rule 12).
*/ -}}
{{define "line-form" -}}
<form id="line-form" class="line-form"
      hx-post="{{if .ID}}/budgets/{{.BudgetID}}/lines/{{.ID}}{{else}}/budgets/{{.BudgetID}}/lines{{end}}"
      hx-target="#line-form" hx-swap="outerHTML">

  <h3>{{if .ID}}{{t "budget.line.form.edit_title"}}{{else}}{{t "budget.line.form.new_title"}}{{end}}</h3>

  <div class="field">
    <label for="lf-sub">{{t "budget.line.form.subsidiary"}}</label>
    {{/* The subsidiary change re-fetches this form so the server re-filters the
         account + fund options to the chosen sub (hx-include carries the current
         values). Edit vs create targets the right GET so the re-filter keeps context. */}}
    <select id="lf-sub" name="subsidiary_id" class="line-sub-select"
            hx-get="{{if .ID}}/budgets/{{.BudgetID}}/lines/{{.ID}}/edit{{else}}/budgets/{{.BudgetID}}/lines/new{{end}}"
            hx-target="#line-form" hx-swap="outerHTML" hx-include="closest form"
            hx-trigger="change">
      {{range .Subs}}<option value="{{.ID}}"{{if eq .ID $.Subsidiary}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </div>

  <div class="field">
    <label for="lf-account">{{t "budget.line.form.account"}}</label>
    <select id="lf-account" name="account_id"
      {{- if eq .Errors.FirstInvalid "account_id"}} autofocus{{end}}>
      <option value="0">{{t "budget.line.form.account_none"}}</option>
      {{range .Accounts}}<option value="{{.ID}}"{{if eq .ID $.AccountID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    <p class="hint">{{t "budget.line.form.account_hint"}}</p>
    {{with .Errors.ErrorKey "account_id"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="lf-fund">{{t "budget.line.form.fund"}}</label>
    <select id="lf-fund" name="fund_id">
      <option value="0">{{t "budget.line.unrestricted"}}</option>
      {{range .Funds}}<option value="{{.ID}}"{{if eq .ID $.FundID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
  </div>

  <div class="field">
    <label for="lf-program">{{t "budget.line.form.program"}}</label>
    <select id="lf-program" name="program_id"
      {{- if eq .Errors.FirstInvalid "program_id"}} autofocus{{end}}>
      {{range .Programs}}<option value="{{.ID}}"{{if eq .ID $.ProgramID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "program_id"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="lf-amount">{{t "budget.line.form.amount"}}</label>
    <input id="lf-amount" name="amount" type="text" value="{{.Amount}}"
      {{- if eq .Errors.FirstInvalid "amount"}} autofocus{{end}}>
    <p class="hint">{{t "budget.line.form.amount_hint"}}</p>
    {{with .Errors.ErrorKey "amount"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="lf-currency">{{t "budget.line.form.currency"}}</label>
    <select id="lf-currency" name="currency">
      {{range .Currencies}}<option value="{{.Code}}"{{if eq .Code $.Currency}} selected{{end}}>{{.Code}} — {{.Name}}</option>
      {{end}}
    </select>
  </div>

  <div class="field">
    <label for="lf-schedule">{{t "budget.line.form.schedule"}}</label>
    <select id="lf-schedule" name="schedule_id"
      {{- if eq .Errors.FirstInvalid "schedule_id"}} autofocus{{end}}>
      <option value="0">{{t "budget.line.form.schedule_none"}}</option>
      {{range .Schedules}}<option value="{{.ID}}"{{if eq .ID $.ScheduleID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    <p class="hint">{{t "budget.line.form.schedule_hint"}}</p>
    {{with .Errors.ErrorKey "schedule_id"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
    <a class="btn btn-ghost" href="/budgets/{{.BudgetID}}">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
