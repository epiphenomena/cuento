{{/*
  Login page (p06.2) + p10.2 language switcher and app.css. The switcher is a set
  of plain <a ?lang=> links (no JS, CSP-safe): the lang middleware honors ?lang and
  sets no cookie, so the choice is per-request until login, after which the user's
  stored locale wins (D14). <html lang> is the resolved locale (.Lang) so the login
  page itself is served in the chosen language. Every string via {{t}} (rule 9).
*/ -}}
{{define "login.tmpl" -}}
<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{t "auth.login_title"}} — {{t "app.name"}}</title>
  <link rel="stylesheet" href="{{asset "app.css"}}">
</head>
<body class="login-body">
  <main class="login-card">
    <h1>{{t "auth.login_title"}}</h1>
    {{if .Error}}<p class="alert" role="alert">{{t .Error}}</p>{{end}}
    <form method="post" action="/login">
      <div class="field">
        <label for="username">{{t "auth.username"}}</label>
        <input id="username" name="username" type="text" autocomplete="username" autofocus required>
      </div>
      <div class="field">
        <label for="password">{{t "auth.password"}}</label>
        <input id="password" name="password" type="password" autocomplete="current-password" required>
      </div>
      <button type="submit" class="btn btn-primary">{{t "auth.sign_in"}}</button>
    </form>
    <nav class="lang-switch" aria-label="{{t "lang.label"}}">
      <span>{{t "lang.label"}}:</span>
      {{range .Langs}}<a href="?lang={{.Code}}"{{if .Current}} aria-current="true"{{end}}>{{.Label}}</a>
      {{end}}
    </nav>
  </main>
</body>
</html>
{{- end}}
