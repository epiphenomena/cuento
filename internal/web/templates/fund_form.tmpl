{{/*
  p12.5 fund create/edit form partial ("fund-form"). SINGLE SOURCE of the form
  region: the page renders the "New fund" trigger inside #fund-form; GET /funds/new
  and /funds/{id}/edit swap THIS partial in (hx-target #fund-form, outerHTML), and a
  failed POST re-renders it at 422 -- so input ids stay stable across every swap
  (anti-jank, Appendix C). The dot is always a fundForm.

  hx-post targets /funds (create) when .ID is 0, else /funds/{id} (edit). Field
  errors come from .Errors (formErrors): .Errors.ErrorKey "field" is the i18n KEY
  (or "") rendered via {{t}} (rule 9); autofocus is stamped on .Errors.FirstInvalid.

  A fund scopes to ONE OR MORE subsidiaries (the sub_<id> CHECKLIST, >=1, D20) and
  OPTIONALLY to a program subtree (the program select; "" = none). The store owns
  validation (ErrFundNoSubsidiary etc.); this form only collects. Fund/subsidiary/
  program names are stored data; every other string via {{t}} (rule 9). No inline
  script/style (strict CSP, rule 12).
*/ -}}
{{define "fund-form" -}}
<form id="fund-form" class="fund-form"
      hx-post="{{if .ID}}/funds/{{.ID}}{{else}}/funds{{end}}"
      hx-target="#fund-form" hx-swap="outerHTML">

  <h2>{{if .ID}}{{t "funds.form.edit_title"}}{{else}}{{t "funds.form.new_title"}}{{end}}</h2>

  <div class="field">
    <label for="ff-name">{{t "funds.form.name"}}</label>
    <input id="ff-name" name="name" type="text" value="{{.Name}}"
      {{- if .Errors.ErrorKey "name"}} aria-invalid="true" aria-describedby="ff-name-err"{{end}}
      {{- if eq .Errors.FirstInvalid "name"}} autofocus{{end}}>
    {{with .Errors.ErrorKey "name"}}<p id="ff-name-err" class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="ff-funder">{{t "funds.form.funder"}}</label>
    <input id="ff-funder" name="funder" type="text" value="{{.Funder}}">
  </div>

  <div class="field">
    <label for="ff-purpose">{{t "funds.form.purpose"}}</label>
    <input id="ff-purpose" name="purpose" type="text" value="{{.Purpose}}">
  </div>

  <div class="field">
    <label for="ff-restriction">{{t "funds.form.restriction"}}</label>
    <select id="ff-restriction" name="restriction">
      {{range $r := (strs "purpose" "time" "perpetual")}}
      <option value="{{$r}}"{{if eq $r $.Restriction}} selected{{end}}>{{t (printf "funds.restriction.%s" $r)}}</option>
      {{end}}
    </select>
  </div>

  <div class="field">
    <label for="ff-program">{{t "funds.form.program"}}</label>
    <select id="ff-program" name="program_id"
      {{- if eq .Errors.FirstInvalid "program_id"}} autofocus{{end}}>
      <option value="0">{{t "funds.form.no_program"}}</option>
      {{range .Programs}}<option value="{{.ID}}"{{if eq .ID $.ProgramID}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "program_id"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="ff-notes">{{t "funds.form.notes"}}</label>
    <input id="ff-notes" name="notes" type="text" value="{{.Notes}}">
  </div>

  <fieldset class="subs-checklist"
    {{- if eq .Errors.FirstInvalid "subs"}} autofocus tabindex="-1"{{end}}>
    <legend>{{t "funds.form.subsidiaries"}}</legend>
    <p class="hint">{{t "funds.form.subs_hint"}}</p>
    {{range .Subs}}
    <label class="check"><input type="checkbox" name="sub_{{.ID}}" value="{{.ID}}"{{if index $.CheckedSubs .ID}} checked{{end}}> {{.Name}}</label>
    {{end}}
    {{with .Errors.ErrorKey "subs"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </fieldset>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
    <a class="btn btn-ghost" href="/funds">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
