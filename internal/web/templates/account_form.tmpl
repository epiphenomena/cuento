{{/*
  p11.1 / p26.7 chart-of-accounts create/edit form partial ("account-form"). SINGLE
  SOURCE of the form region, embedded by account_form_page.tmpl (the dedicated
  full-shell create/edit page, p26.7). The dot is always an accountForm.

  A PLAIN full-page POST (method=post action=/accounts | /accounts/{id}) -- NOT an
  htmx target swap: on success the handler 303-redirects to /accounts (PRG); on a
  store typed error it re-renders the WHOLE page at 422 with the field error +
  autofocus on the first invalid control (anti-jank: input ids stay stable across
  the re-render, Appendix C). Field errors come from .Errors (formErrors):
  .Errors.ErrorKey "field" is the i18n KEY (or "") rendered via {{t}} (rule 9);
  autofocus is stamped on .Errors.FirstInvalid only. No inline script/style (rule 12).

  Type-dependent regions: the functional-class select shows only for expense
  accounts (.IsExpense), the default-program select only for revenue/expense
  (.IsRE). Changing type re-fetches JUST this form region (hx-get on the type
  select, hx-target #account-form, outerHTML) so those regions and the filtered
  990/parent options refresh in place on the standalone page; the handler serves
  the bare partial for that swap (HX-Target header) and the full page otherwise. A
  full submit still validates server-side (the store is the source of truth).
*/ -}}
{{define "account-form" -}}
<form id="account-form" class="account-form" method="post"
      action="{{if .ID}}/accounts/{{.ID}}{{else}}/accounts{{end}}">

  <div class="field">
    <label for="af-type">{{t "accounts.form.type"}}</label>
    <select id="af-type" name="type"
            hx-get="{{if .ID}}/accounts/{{.ID}}/edit{{else}}/accounts/new{{end}}"
            hx-target="#account-form" hx-swap="outerHTML" hx-include="closest form">
      {{range $t := (strs "asset" "liability" "equity" "revenue" "expense")}}
      <option value="{{$t}}"{{if eq $t $.Type}} selected{{end}}>{{t (printf "account.type.%s" $t)}}</option>
      {{end}}
    </select>
  </div>

  {{/*
    One name input per ENABLED language (p11.4, D14): the .Names set is driven by
    the org's enabled_languages, so adding a language makes a new column appear. en
    (.Required) keeps its stable field name "name_en" and id "af-name-en" and shows
    the ErrNameRequired autofocus/error; the label is the interpolated "Name (%s)"
    so any language gets a label without a per-language chrome key (chrome stays
    en/es via fallback).
  */ -}}
  {{range .Names}}
  {{$ni := .}}
  <div class="field">
    <label for="{{$ni.ID}}">{{t "accounts.form.name" $ni.LabelArg}}</label>
    <input id="{{$ni.ID}}" name="{{$ni.Field}}" type="text" value="{{$ni.Value}}"
      {{- if $.Errors.ErrorKey $ni.Field}} aria-invalid="true" aria-describedby="{{$ni.ID}}-err"{{end}}
      {{- if eq $.Errors.FirstInvalid $ni.Field}} autofocus{{end}}>
    {{with $.Errors.ErrorKey $ni.Field}}<p id="{{$ni.ID}}-err" class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>
  {{end}}

  <div class="field">
    <label for="af-parent">{{t "accounts.form.parent"}}</label>
    {{/* p28.2: fuzzy account combobox (combo-input); data-path carries the dotted
         hierarchy so a query like "c.boa" ranks "Cash.BOA". */}}
    <select id="af-parent" name="parent_id" class="combo-input"
      {{- if eq .Errors.FirstInvalid "parent_id"}} autofocus{{end}}>
      <option value="0">{{t "accounts.form.no_parent"}}</option>
      {{range .Parents}}<option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $.ParentID}} selected{{end}}>{{.Path}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "parent_id"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="af-currency">{{t "accounts.form.currency"}}</label>
    <select id="af-currency" name="currency">
      {{range .Currencies}}<option value="{{.Code}}"{{if eq .Code $.Currency}} selected{{end}}>{{.Code}} — {{.Name}}</option>
      {{end}}
    </select>
  </div>

  {{/* p28.7: a free-text note ABOUT the account (a description/reminder), NOT the
       account name. Shown in the chart-of-accounts column the per-row type used to
       occupy. Optional; blank clears it. */}}
  <div class="field">
    <label for="af-notes">{{t "accounts.form.notes"}}</label>
    <textarea id="af-notes" name="notes" rows="2" class="account-notes">{{.Notes}}</textarea>
  </div>

  <div class="field check">
    <label><input type="checkbox" name="reconcilable" value="on"{{if .Reconcilable}} checked{{end}}> {{t "accounts.form.reconcilable"}}</label>
  </div>
  <div class="field check">
    <label><input type="checkbox" name="intercompany" value="on"{{if .Intercompany}} checked{{end}}> {{t "accounts.form.intercompany"}}</label>
  </div>

  {{/*
    p27.1 boolean type-flags. current_cash shows only for ASSET accounts; open_item
    for ASSET or LIABILITY. The type-select re-fetch (above) refreshes these regions
    on a type change, exactly like the functional-class / default-program regions.
    The SERVER still enforces the rule (the store rejects a wrong-type flag); this
    gating only hides an irrelevant control. A store rejection maps to a field error
    here (autofocus on the offending checkbox).
  */ -}}
  {{if .IsAsset}}
  <div class="field check">
    <label><input type="checkbox" name="current_cash" value="on"{{if .CurrentCash}} checked{{end}}
      {{- if eq .Errors.FirstInvalid "current_cash"}} autofocus{{end}}> {{t "accounts.form.current_cash"}}</label>
    <p class="hint">{{t "accounts.form.current_cash_help"}}</p>
    {{with .Errors.ErrorKey "current_cash"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>
  {{end}}
  {{if .IsAssetOrLiability}}
  <div class="field check">
    <label><input type="checkbox" name="open_item" value="on"{{if .OpenItem}} checked{{end}}
      {{- if eq .Errors.FirstInvalid "open_item"}} autofocus{{end}}> {{t "accounts.form.open_item"}}</label>
    <p class="hint">{{t "accounts.form.open_item_help"}}</p>
    {{with .Errors.ErrorKey "open_item"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>
  {{end}}
  {{/*
    A wrong-type flag submission (a client sending current_cash/open_item for an
    ineligible type -- the UI hides the control, so this is an out-of-band submit)
    is rejected by the store; surface that error even when the gated control above
    is hidden, so the 422 re-render is not silent.
  */ -}}
  {{if and (not .IsAsset) (.Errors.ErrorKey "current_cash")}}<p class="field-error" role="alert">{{t (.Errors.ErrorKey "current_cash")}}</p>{{end}}
  {{if and (not .IsAssetOrLiability) (.Errors.ErrorKey "open_item")}}<p class="field-error" role="alert">{{t (.Errors.ErrorKey "open_item")}}</p>{{end}}

  {{if .IsExpense}}
  <div class="field">
    <label for="af-func">{{t "accounts.form.functional_class"}}</label>
    <select id="af-func" name="functional_class"
      {{- if eq .Errors.FirstInvalid "functional_class"}} autofocus{{end}}>
      <option value="">{{t "accounts.form.none"}}</option>
      {{range $c := (strs "program" "management" "fundraising")}}
      <option value="{{$c}}"{{if eq $c $.FunctionalClass}} selected{{end}}>{{t (printf "functional.%s" $c)}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "functional_class"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>
  {{end}}

  {{if .IsRE}}
  <div class="field">
    <label for="af-program">{{t "accounts.form.default_program"}}</label>
    {{/* p29.13: fuzzy program combobox (combo-input) with the dotted hierarchy in data-path. */}}
    <select id="af-program" name="default_program" class="combo-input"
      {{- if eq .Errors.FirstInvalid "default_program"}} autofocus{{end}}>
      <option value="0">{{t "accounts.form.none"}}</option>
      {{range .Programs}}<option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $.DefaultProgram}} selected{{end}}>{{.Name}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "default_program"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>
  {{end}}

  <div class="field">
    <label for="af-990">{{t "accounts.form.form990_code"}}</label>
    <select id="af-990" name="form990_code"
      {{- if eq .Errors.FirstInvalid "form990_code"}} autofocus{{end}}>
      <option value="">{{if .Form990Effective}}{{t "accounts.form.form990_inherited"}} {{.Form990Effective}}{{else}}{{t "accounts.form.none"}}{{end}}</option>
      {{range .Lines}}<option value="{{.Code}}"{{if eq .Code $.Form990Code}} selected{{end}}>{{.Code}} — {{.Label}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "form990_code"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <fieldset class="subs-checklist"
    {{- if eq .Errors.FirstInvalid "subs"}} autofocus tabindex="-1"{{end}}>
    <legend>{{t "accounts.form.subsidiaries"}}</legend>
    <p class="hint">{{t "accounts.form.subs_hint"}}</p>
    {{range .Subs}}
    <label class="check"><input type="checkbox" name="sub_{{.ID}}" value="{{.ID}}"{{if index $.CheckedSubs .ID}} checked{{end}}> {{.Name}}</label>
    {{end}}
    {{with .Errors.ErrorKey "subs"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </fieldset>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
    <a class="btn btn-ghost" href="/accounts">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
