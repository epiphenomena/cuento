{{/*
  p19.3 schedule create/edit form partial ("schedule-form"). SINGLE SOURCE of the
  form region: the library page renders the "New schedule" trigger inside
  #schedule-form; GET /schedules/new and /{id}/edit swap THIS partial in
  (hx-target #schedule-form, outerHTML), and a failed POST re-renders it at 422 -- so
  input ids stay stable across every swap (anti-jank, Appendix C). The dot is always a
  scheduleFormModel.

  hx-post targets /schedules (create) when .ID is 0, else
  /schedules/{id} (edit). Field errors come from .Errors (formErrors), i18n
  KEYS rendered via {{t}} (rule 9); autofocus on .Errors.FirstInvalid.

  KIND-SPECIFIC PICKERS: ALL kind blocks are rendered here (each tagged
  data-kind-field="<kind>"); a small CSP-safe ES module (budgetkind.js, loaded by the
  LIBRARY PAGE that swaps this partial in -- a <script> inside a swapped partial would
  not execute) SHOWS the block(s) for the chosen kind and HIDES the rest on a kind
  change -- NO server round-trip, so there is NO htmx settle race on the kind select
  (DECISIONS p19.3). Because every block is rendered at once and `hidden` does NOT stop
  form submission, controls that would otherwise SHARE a field name across blocks carry
  KIND-UNIQUE names (sm_day_of_month, weekly_weekday, weekly_anchor) so the handler
  reads the right block's value per kind (r.PostFormValue returns the first-in-DOM
  control for a shared name). A full submit still validates server-side (the store's
  engine is the source of truth for field consistency, ErrScheduleInvalid). The
  weekend-policy select shows only for the day-of-month kinds (monthly-by-DoM,
  semimonthly), tagged data-kind-weekend.

  No inline script/style (strict CSP, rule 12).
*/ -}}
{{define "schedule-form" -}}
<form id="schedule-form" class="schedule-form"
      hx-post="{{if .ID}}/schedules/{{.ID}}{{else}}/schedules{{end}}"
      hx-target="#schedule-form" hx-swap="outerHTML">

  <h2>{{if .ID}}{{t "budget.schedule.form.edit_title"}}{{else}}{{t "budget.schedule.form.new_title"}}{{end}}</h2>

  <div class="field">
    <label for="sf-name">{{t "budget.schedule.form.name"}}</label>
    <input id="sf-name" name="name" type="text" value="{{.Name}}"
      {{- if .Errors.ErrorKey "name"}} aria-invalid="true" aria-describedby="sf-name-err"{{end}}
      {{- if eq .Errors.FirstInvalid "name"}} autofocus{{end}}>
    {{with .Errors.ErrorKey "name"}}<p id="sf-name-err" class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  <div class="field">
    <label for="sf-kind">{{t "budget.schedule.form.kind"}}</label>
    <select id="sf-kind" name="kind" class="schedule-kind-select"
      {{- if eq .Errors.FirstInvalid "kind"}} autofocus{{end}}>
      {{range .Kinds}}<option value="{{.}}"{{if eq . $.Kind}} selected{{end}}>{{t (printf "budget.kind.%s" .)}}</option>
      {{end}}
    </select>
    {{with .Errors.ErrorKey "kind"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
  </div>

  {{/* --- onetime / annual / biweekly: an anchor date --- */}}
  <div class="kind-block" data-kind-field="onetime annual biweekly">
    <div class="field">
      <label for="sf-anchor">{{t "budget.schedule.form.anchor_date"}}</label>
      <input id="sf-anchor" name="anchor_date" type="text" class="js-datefield" value="{{.AnchorDate}}"
             placeholder="{{t "budget.schedule.form.date_placeholder"}}">
      <p class="hint">{{t "budget.schedule.form.anchor_hint"}}</p>
    </div>
  </div>

  {{/* --- monthly: day-of-month OR ordinal weekday --- */}}
  <div class="kind-block" data-kind-field="monthly">
    <div class="field">
      <label for="sf-dom">{{t "budget.schedule.form.day_of_month"}}</label>
      <select id="sf-dom" name="day_of_month">
        <option value="0">{{t "budget.schedule.form.dom_none"}}</option>
        {{range .DaysOfMonth}}<option value="{{.}}"{{if eq . $.DayOfMonth}} selected{{end}}>{{if eq . -1}}{{t "budget.dom.last"}}{{else}}{{.}}{{end}}</option>
        {{end}}
      </select>
      <p class="hint">{{t "budget.schedule.form.monthly_hint"}}</p>
    </div>
    <div class="field">
      <label for="sf-ordinal">{{t "budget.schedule.form.ordinal"}}</label>
      <select id="sf-ordinal" name="ordinal">
        <option value="0">{{t "budget.schedule.form.ordinal_none"}}</option>
        {{range .Ordinals}}<option value="{{.}}"{{if eq . $.Ordinal}} selected{{end}}>{{t (printf "budget.ordinal.%s" (ordKey .))}}</option>
        {{end}}
      </select>
    </div>
    <div class="field">
      <label for="sf-mweekday">{{t "budget.schedule.form.weekday"}}</label>
      <select id="sf-mweekday" name="weekday">
        {{range .Weekdays}}<option value="{{.}}"{{if eq . $.Weekday}} selected{{end}}>{{t (printf "budget.weekday.%d" .)}}</option>
        {{end}}
      </select>
    </div>
  </div>

  {{/* --- semimonthly: two days-of-month. NOTE the first day's field name is
       DISTINCT (sm_day_of_month) from the monthly block's day_of_month: every kind
       block is rendered at once (JS only toggles visibility, which does NOT stop
       submission), so a shared name would let r.PostFormValue read the WRONG block's
       first-in-DOM control. Each colliding control gets a kind-unique name and the
       handler reads it per kind. --- */}}
  <div class="kind-block" data-kind-field="semimonthly">
    <div class="field">
      <label for="sf-dom-a">{{t "budget.schedule.form.day_of_month"}} 1</label>
      <select id="sf-dom-a" name="sm_day_of_month">
        <option value="0">{{t "budget.schedule.form.dom_none"}}</option>
        {{range .DaysOfMonth}}<option value="{{.}}"{{if eq . $.DayOfMonth}} selected{{end}}>{{if eq . -1}}{{t "budget.dom.last"}}{{else}}{{.}}{{end}}</option>
        {{end}}
      </select>
    </div>
    <div class="field">
      <label for="sf-dom-b">{{t "budget.schedule.form.day_of_month"}} 2</label>
      <select id="sf-dom-b" name="day_of_month_2">
        <option value="0">{{t "budget.schedule.form.dom_none"}}</option>
        {{range .DaysOfMonth}}<option value="{{.}}"{{if eq . $.DayOfMonth2}} selected{{end}}>{{if eq . -1}}{{t "budget.dom.last"}}{{else}}{{.}}{{end}}</option>
        {{end}}
      </select>
    </div>
  </div>

  {{/* --- weekly: a weekday + anchor. Kind-unique names (weekly_weekday,
       weekly_anchor) for the same collision reason as semimonthly above. --- */}}
  <div class="kind-block" data-kind-field="weekly">
    <div class="field">
      <label for="sf-wweekday">{{t "budget.schedule.form.weekday"}}</label>
      <select id="sf-wweekday" name="weekly_weekday">
        {{range .Weekdays}}<option value="{{.}}"{{if eq . $.Weekday}} selected{{end}}>{{t (printf "budget.weekday.%d" .)}}</option>
        {{end}}
      </select>
    </div>
    <div class="field">
      <label for="sf-wanchor">{{t "budget.schedule.form.anchor_date"}}</label>
      <input id="sf-wanchor" name="weekly_anchor" type="text" class="js-datefield" value="{{.AnchorDate}}"
             placeholder="{{t "budget.schedule.form.date_placeholder"}}">
    </div>
  </div>

  {{/* --- custom: an imported list of dates (one per line) --- */}}
  <div class="kind-block" data-kind-field="custom">
    <div class="field">
      <label for="sf-custom">{{t "budget.schedule.form.custom_dates"}}</label>
      <textarea id="sf-custom" name="custom_dates" rows="6"
        {{- if eq .Errors.FirstInvalid "custom_dates"}} autofocus{{end}}>{{.CustomDates}}</textarea>
      <p class="hint">{{t "budget.schedule.form.custom_hint"}}</p>
      {{with .Errors.ErrorKey "custom_dates"}}<p class="field-error" role="alert">{{t .}}</p>{{end}}
    </div>
  </div>

  {{/* --- weekend policy: only for day-of-month kinds (JS toggles) --- */}}
  <div class="kind-block" data-kind-weekend="monthly semimonthly">
    <div class="field">
      <label for="sf-weekend">{{t "budget.schedule.form.weekend_adjust"}}</label>
      <select id="sf-weekend" name="weekend_adjust">
        {{range .WeekendPolicies}}<option value="{{.}}"{{if eq . $.Weekend}} selected{{end}}>{{t (printf "budget.weekend.%s" .)}}</option>
        {{end}}
      </select>
      <p class="hint">{{t "budget.schedule.form.weekend_hint"}}</p>
    </div>
  </div>

  <div class="field">
    <label for="sf-notes">{{t "budget.schedule.form.notes"}}</label>
    <input id="sf-notes" name="notes" type="text" value="{{.Notes}}">
  </div>

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">{{t "common.save"}}</button>
    <a class="btn btn-ghost" href="/schedules">{{t "common.cancel"}}</a>
  </div>
</form>
{{- end}}
