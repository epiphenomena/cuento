{{/*
  p11.1 chart of accounts page (also the home landing, p23.8). Self-contained shell
  page (shell-open / <main> / shell-close). .Page is an accountsPageModel.

  p23.10: the subsidiary + active filters and the New/Merge triggers live in the
  SECOND-LEVEL menu (the "accounts-controls" partial the shell renders in the
  section bar), not the page body. The filter form auto-applies on change (htmx GET
  swapping #accounts-results) — no Apply button — and degrades to a plain GET form
  (Enter submits, full reload) with no JS. The results (as-of + tree table) live in
  "accounts-results" so a filter change swaps only them, leaving any open
  create/edit form in #account-form untouched.

  Tree rows are indented by depth (rule: names are stored/proper, rendered verbatim);
  balances go through the money formatter (rule 10); every other string via {{t}}
  (rule 9); no inline script (rule 12).
*/ -}}

{{/* accounts-controls: the section-bar controls (p23.10). Dot is the accountsPageModel. */ -}}
{{define "accounts-controls" -}}
{{- with .}}
<form class="subnav-filters" method="get" action="/accounts"
      hx-get="/accounts" hx-trigger="change" hx-target="#accounts-results" hx-swap="outerHTML">
  <label for="sub-filter">{{t "accounts.filter.subsidiary"}}</label>
  <select id="sub-filter" name="sub">
    <option value="0">{{t "accounts.filter.all_subsidiaries"}}</option>
    {{range .Subs}}<option value="{{.ID}}"{{if eq .ID $.SubFilter}} selected{{end}}>{{.Name}}</option>
    {{end}}
  </select>
  <label class="check">
    <input type="checkbox" name="active" value="1"{{if .ActiveOnly}} checked{{end}}>
    {{t "accounts.filter.active_only"}}
  </label>
  {{/* No-JS fallback: without htmx the change-trigger can't fire, so keep a submit. */}}
  <noscript><button type="submit" class="btn">{{t "accounts.filter.apply"}}</button></noscript>
</form>
<div class="subnav-actions">
  <button type="button" class="btn btn-primary"
          hx-get="/accounts/new" hx-target="#account-form" hx-swap="outerHTML">
    {{t "accounts.new"}}
  </button>
  <button type="button" class="btn btn-ghost"
          hx-get="/accounts/merge" hx-target="#account-form" hx-swap="outerHTML">
    {{t "accounts.merge"}}
  </button>
</div>
{{- end}}
{{- end}}

{{/* accounts-results: the as-of line + tree table. Swapped alone on a filter change
     (hx-target #accounts-results). Dot is the accountsPageModel. */ -}}
{{define "accounts-results" -}}
{{- with .}}
<div id="accounts-results">
  <p class="asof">{{t "accounts.balances_as_of"}} {{.AsOf}}</p>
  <table class="tree-table">
    <thead>
      <tr>
        <th>{{t "accounts.col.name"}}</th>
        <th>{{t "accounts.col.type"}}</th>
        <th>{{t "accounts.col.balances"}}</th>
        <th>{{t "accounts.col.actions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{range .Rows}}
      <tr class="acct-row{{if not .Active}} acct-inactive{{end}}" data-depth="{{.Depth}}">
        <td class="acct-name acct-depth-{{.Depth}}">{{.Name}}{{if not .Active}} <span class="badge">{{t "accounts.inactive"}}</span>{{end}}</td>
        <td>{{t (printf "account.type.%s" .Type)}}</td>
        <td class="acct-balances">
          {{range .Balances}}<span class="bal">{{.}}</span> {{end}}
        </td>
        <td class="acct-actions">
          <a class="btn btn-ghost" href="/accounts/{{.ID}}/register">{{t "accounts.register"}}</a>
          <button type="button" class="btn btn-ghost"
                  hx-get="/accounts/{{.ID}}/edit" hx-target="#account-form" hx-swap="outerHTML">
            {{t "common.edit"}}
          </button>
          {{if .Active}}
          <form method="post" action="/accounts/{{.ID}}/deactivate" class="inline">
            <button type="submit" class="btn btn-ghost">{{t "accounts.deactivate"}}</button>
          </form>
          {{end}}
        </td>
      </tr>
      {{else}}
      <tr><td colspan="4">{{t "accounts.empty"}}</td></tr>
      {{end}}
    </tbody>
  </table>
</div>
{{- end}}
{{- end}}

{{define "accounts.tmpl" -}}
{{template "shell-open" (shellTitle . (t "accounts.title"))}}
  {{- with .Page}}
  <h1>{{t "accounts.title"}}</h1>

  {{/* The inline create/edit/merge form swaps in here; the New/Merge triggers live
       in the section bar (p23.10) and target this region. Empty until opened. */}}
  <div id="account-form" class="account-form-region"></div>

  {{template "accounts-results" .}}
  {{- end}}
{{template "shell-close" .}}
{{- end}}
