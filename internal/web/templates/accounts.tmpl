{{/*
  p11.1 chart of accounts page (also the home landing, p23.8). Self-contained shell
  page (shell-open / <main> / shell-close). .Page is an accountsPageModel.

  p23.10: the subsidiary + active filters and the New/Merge triggers live in the
  SECOND-LEVEL menu (the "accounts-controls" partial the shell renders in the
  section bar), not the page body. The filter form auto-applies on change (htmx GET
  swapping #accounts-results) — no Apply button — and degrades to a plain GET form
  (Enter submits, full reload) with no JS. The results (as-of + tree table) live in
  "accounts-results" so a filter change swaps only them, leaving any open
  create/edit form in #account-form untouched.

  Tree rows are indented by depth (rule: names are stored/proper, rendered verbatim);
  balances go through the money formatter (rule 10); every other string via {{t}}
  (rule 9); no inline script (rule 12).
*/ -}}

{{/* accounts-controls: the section-bar controls (p23.10). Dot is the accountsPageModel. */ -}}
{{define "accounts-controls" -}}
{{- with .}}
{{/* p26.90: hx-sync="this:replace" ABORTS any in-flight filter GET when a new change
     fires (sub/type/active can change in quick succession), so the LATEST response always
     wins — no out-of-order swap. */ -}}
<form class="subnav-filters" method="get" action="/accounts"
      hx-get="/accounts" hx-trigger="change" hx-target="#accounts-results" hx-swap="outerHTML"
      hx-sync="this:replace">
  <label for="sub-filter">{{t "accounts.filter.subsidiary"}}</label>
  <select id="sub-filter" name="sub">
    <option value="0">{{t "accounts.filter.all_subsidiaries"}}</option>
    {{range .Subs}}<option value="{{.ID}}"{{if eq .ID $.SubFilter}} selected{{end}}>{{.Name}}</option>
    {{end}}
  </select>
  {{/* p26.75: account-type filter -- show only one type's group. Rides the SAME filter
       form (so it submits alongside `sub`, the deliberate-submit discriminator) and is
       persisted like the sub/active filters. The option labels reuse the plural
       account.section.* section labels, matching the injected chart headers. */}}
  <label for="type-filter">{{t "accounts.filter.type"}}</label>
  <select id="type-filter" name="type">
    <option value="">{{t "accounts.filter.all_types"}}</option>
    <option value="asset"{{if eq "asset" .TypeFilter}} selected{{end}}>{{t "account.section.asset"}}</option>
    <option value="liability"{{if eq "liability" .TypeFilter}} selected{{end}}>{{t "account.section.liability"}}</option>
    <option value="equity"{{if eq "equity" .TypeFilter}} selected{{end}}>{{t "account.section.equity"}}</option>
    <option value="revenue"{{if eq "revenue" .TypeFilter}} selected{{end}}>{{t "account.section.revenue"}}</option>
    <option value="expense"{{if eq "expense" .TypeFilter}} selected{{end}}>{{t "account.section.expense"}}</option>
  </select>
  <label class="check">
    <input type="checkbox" name="active" value="1"{{if .ActiveOnly}} checked{{end}}>
    {{t "accounts.filter.active_only"}}
  </label>
  {{/* No-JS fallback: without htmx the change-trigger can't fire, so keep a submit. */}}
  <noscript><button type="submit" class="btn">{{t "accounts.filter.apply"}}</button></noscript>
  {{/* p28.30: non-disruptive "updating…" cue while a filter GET is in flight (same
       mechanism as the report filters: form gets .htmx-request, this span fades in). */}}
  <span class="htmx-indicator subnav-updating" aria-hidden="true">{{t "common.updating"}}</span>
</form>
<div class="subnav-actions">
  {{/* p26.7: New opens a dedicated full page (GET /accounts/new) -- a plain link, so
       the form is always on-screen even when the tree is scrolled. Merge stays inline
       (its two-step preview swaps into #account-form below). */}}
  <a class="btn btn-primary" href="/accounts/new">{{t "accounts.new"}}</a>
  <button type="button" class="btn btn-ghost"
          hx-get="/accounts/merge" hx-target="#account-form" hx-swap="outerHTML">
    {{t "accounts.merge"}}
  </button>
</div>
{{- end}}
{{- end}}

{{/* accounts-results: the as-of line + tree table. Swapped alone on a filter change
     (hx-target #accounts-results). Dot is the accountsPageModel. */ -}}
{{define "accounts-results" -}}
{{- with .}}
<div id="accounts-results">
  <p class="asof">{{t "accounts.balances_as_of"}} {{.AsOf}}</p>
  {{/* p26.25: tree collapse/expand controls. treetable.js reveals these (they carry
       `hidden` so a no-JS user sees the full tree with inert, hidden buttons) and
       wires them to the tree below. They live INSIDE #accounts-results so the htmx
       filter swap re-renders controls + table together (no stale references). */}}
  <div class="accounts-controls tree-controls">
    <button type="button" class="btn btn-ghost tree-collapse-all" hidden>{{t "tree.collapse_all"}}</button>
    <button type="button" class="btn btn-ghost tree-expand-level" hidden>{{t "tree.expand_level"}}</button>
    <button type="button" class="btn btn-ghost tree-expand-all" hidden>{{t "tree.expand_all"}}</button>
  </div>
  <table class="tree-table">
    <thead>
      <tr>
        <th>{{t "accounts.col.name"}}</th>
        {{/* p28.8: the chart already GROUPS by type (p26.74 headers), so the per-row
             Type column is redundant -- replaced by the account's free-text Notes. */}}
        <th>{{t "accounts.col.notes"}}</th>
        <th class="acct-balances">{{t "accounts.col.balances"}}</th>
        <th>{{t "accounts.col.actions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{range .Rows}}
      {{if .Header}}
      {{/* p26.74: injected TYPE-TIER header ("Assets"/"Liabilities"/…). Display-only
           and non-selectable -- no register link, no balances, no account actions:
           it is not a real account. It participates in treetable collapse/expand as
           the shallowest (depth-0) row of its block; its name cell holds NO <a>, so
           the p26.55 name-click toggle applies. */}}
      <tr class="acct-row acct-type-header" data-depth="{{.Depth}}">
        <td class="acct-name acct-depth-{{.Depth}}">{{t .TypeLabelKey}}</td>
        <td></td>
        <td class="acct-balances"></td>
        <td class="acct-actions"></td>
      </tr>
      {{else}}
      <tr class="acct-row{{if not .Active}} acct-inactive{{end}}" data-depth="{{.Depth}}">
        {{/* p25: the account name opens its register (the everyday drill-down); the
             dedicated Register button is gone. */}}
        <td class="acct-name acct-depth-{{.Depth}}"><a href="/accounts/{{.ID}}/register">{{.Name}}</a>{{if .CurrentCash}} <span class="badge badge-current-cash" title="{{t "accounts.form.current_cash"}}">{{t "accounts.badge.cash"}}</span>{{end}}{{if .BadgeKey}} <span class="badge badge-open-item">{{t .BadgeKey}}</span>{{end}}{{if not .Active}} <span class="badge">{{t "accounts.inactive"}}</span>{{end}}</td>
        {{/* p28.8: free-text Notes replaces the redundant Type. Rendered verbatim (stored data). */}}
        <td class="acct-notes">{{.Notes}}</td>
        <td class="acct-balances">
          {{range .Balances}}<span class="bal">{{.}}</span> {{end}}
        </td>
        <td class="acct-actions">
          {{if .Reconcilable}}
          {{/* p25: reconcilable accounts get a reconcile affordance -> the recon list,
               anchored to this account's start row. */}}
          <a class="btn btn-ghost" href="/reconciliations#recon-acct-{{.ID}}">{{t "accounts.reconcile"}}</a>
          {{end}}
          {{/* p26.7: Edit opens a dedicated full page (GET /accounts/{id}/edit). */}}
          <a class="btn btn-ghost" href="/accounts/{{.ID}}/edit">{{t "common.edit"}}</a>
          {{if .Active}}
          <form method="post" action="/accounts/{{.ID}}/deactivate" class="inline">
            <button type="submit" class="btn btn-ghost">{{t "accounts.deactivate"}}</button>
          </form>
          {{end}}
        </td>
      </tr>
      {{end}}
      {{else}}
      <tr><td colspan="4">{{t "accounts.empty"}}</td></tr>
      {{end}}
    </tbody>
  </table>
</div>
{{- end}}
{{- end}}

{{define "accounts.tmpl" -}}
{{template "shell-open" (shellTitle . (t "accounts.title"))}}
  {{- with .Page}}
  <h1>{{t "accounts.title"}}</h1>

  {{/* p26.7: create/edit moved to their own pages (GET /accounts/new,
       /accounts/{id}/edit); this region now hosts only the inline MERGE form + its
       two-step preview (the Merge trigger in the section bar targets it). Empty
       until Merge is opened. */}}
  <div id="account-form" class="account-form-region"></div>

  {{/* p28.9: EPHEMERAL fuzzy search over the chart rows. Lives OUTSIDE
       #accounts-results (so a filter swap does not wipe the typed text) and is NOT a
       named field of the persisted filter form, has no session key and no route -- so
       it resets on every navigation, unlike the sub/active/type filters. chartsearch.js
       (loaded on the page) filters the rows client-side; with no JS the box is inert
       and the full tree shows. */}}
  <div class="chart-search">
    <label for="acct-search">{{t "accounts.search.label"}}</label>
    <input type="text" id="acct-search" class="chart-search-input"
           placeholder="{{t "accounts.search.placeholder"}}" autocomplete="off">
  </div>

  {{template "accounts-results" .}}
  {{/* p26.25: the reusable tree collapse/expand module. Loaded on the PAGE (not the
       swapped #accounts-results partial: a <script> injected via htmx innerHTML does
       not execute). It self-inits on DOMContentLoaded and re-runs on htmx:afterSwap
       when the filter replaces #accounts-results, re-wiring the fresh table. */}}
  <script type="module" src="{{asset "treetable.js"}}"></script>
  {{/* p28.9: the ephemeral chart search. Loaded on the PAGE (the input lives outside
       the swapped #accounts-results, so it is never re-rendered); it self-inits on
       DOMContentLoaded and re-applies the current query on htmx:afterSwap. */}}
  <script type="module" src="{{asset "chartsearch.js"}}"></script>
  {{- end}}
{{template "shell-close" .}}
{{- end}}
