{{/*
  p13.2 admin per-user permissions (GET /admin/users/{id}, Admin). Two small
  full-page forms, each its own VERSIONED change: the txn_perm select (POST
  .../txn-perm) and the report-group grant checkboxes (POST .../grants, the full
  desired set diffed server-side into grants/revokes). Both 303-redirect back here
  with a saved notice (PRG). .Page is a userDetailModel. Every string via {{t}}
  (rule 9); no inline script (rule 12); the username/display name are stored data.
*/ -}}
{{define "admin_user_detail.tmpl" -}}
{{template "shell-open" (shellTitle . (t "admin.users.permissions"))}}
  {{- with .Page}}
  <p><a href="/admin/users">&larr; {{t "admin.users.title"}}</a></p>
  <h1>{{.Username}}</h1>
  {{if .DisplayName}}<p class="hint">{{.DisplayName}}</p>{{end}}
  {{if .Disabled}}<p class="badge">{{t "admin.users.disabled"}}</p>{{end}}
  {{if .IsAdmin}}<p class="hint">{{t "admin.users.admin_note"}}</p>{{end}}

  {{if .Saved}}
  <p class="notice" role="status">{{t "admin.users.saved"}}</p>
  {{end}}

  {{if .ErrorKey}}
  <p class="error" role="alert">{{t .ErrorKey}}</p>
  {{end}}

  <section class="display-name-section">
    <h2>{{t "admin.users.display_name_title"}}</h2>
    <form method="post" action="/admin/users/{{.ID}}/display-name" class="display-name-form">
      <div class="field">
        <label for="ud-display-name">{{t "admin.users.form.display_name"}}</label>
        <input id="ud-display-name" name="display_name" type="text" value="{{.DisplayName}}"
               autocomplete="off" maxlength="200"
               {{- if eq .ErrorField "display_name"}} autofocus aria-invalid="true"{{end}}>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{t "admin.users.save_display_name"}}</button>
      </div>
    </form>
  </section>

  <section class="perm-section">
    <h2>{{t "admin.users.txn_perm_title"}}</h2>
    <form method="post" action="/admin/users/{{.ID}}/txn-perm" class="txn-perm-form">
      <div class="field">
        <label for="ud-perm">{{t "admin.users.form.txn_perm"}}</label>
        <select id="ud-perm" name="txn_perm"
          {{- if eq .ErrorField "txn_perm"}} autofocus aria-invalid="true"{{end}}>
          {{- range .TxnPerms}}
          <option value="{{.Value}}"{{if eq .Value $.Page.TxnPerm}} selected{{end}}>{{t .LabelKey}}</option>
          {{- end}}
        </select>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{t "admin.users.save_perm"}}</button>
      </div>
    </form>
  </section>

  <section class="reset-pw-section">
    <h2>{{t "admin.users.reset_password"}}</h2>
    <form method="post" action="/admin/users/{{.ID}}/reset-password" class="reset-pw-form">
      <div class="field">
        <label for="ud-password">{{t "admin.users.new_password"}}</label>
        <input id="ud-password" name="password" type="password" autocomplete="new-password"
               aria-label="{{t "admin.users.new_password"}}">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{t "admin.users.reset_password"}}</button>
      </div>
    </form>
  </section>

  <section class="submit-section">
    <h2>{{t "admin.users.submit_title"}}</h2>
    <p class="hint">{{t "admin.users.submit_intro"}}</p>
    <form method="post" action="/admin/users/{{.ID}}/can-submit" class="can-submit-form">
      <div class="field field-check">
        <label>
          <input type="checkbox" name="can_submit_expenses" value="1"{{if .CanSubmitExpenses}} checked{{end}}>
          {{t "admin.users.form.can_submit"}}
        </label>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{t "admin.users.save_submit"}}</button>
      </div>
    </form>
  </section>

  <section class="grant-section">
    <h2>{{t "admin.users.grants_title"}}</h2>
    <p class="hint">{{t "admin.users.grants_intro"}}</p>
    <form method="post" action="/admin/users/{{.ID}}/grants" class="grants-form">
      {{- $programs := .Programs}}
      {{- if .Grants}}
      <div class="grant-groups">
        {{- range $grant := .Grants}}
        {{- $label := t (printf "reports.group.%s" $grant.Name)}}
        <fieldset class="grant-group{{if $grant.ScopeSelectable}} grant-group-scoped{{end}}">
          <legend>{{$label}}</legend>
          <div class="field field-check grant-row">
            <label>
              <input type="checkbox" name="grant_{{$grant.Name}}" value="1"{{if $grant.Granted}} checked{{end}}>
              {{t "admin.users.grant_group_access"}}
            </label>
          </div>
          {{- if $grant.ScopeSelectable}}
          <div class="grant-scope">
            <label for="grant-scope-{{$grant.Name}}">{{t "admin.users.grant_scope_for" $label}}</label>
            {{/* p29.13: fuzzy program combobox (combo-input) with the dotted hierarchy in data-path. */}}
            <select id="grant-scope-{{$grant.Name}}" name="program_{{$grant.Name}}" class="combo-input">
              <option value="">{{t "admin.users.grant_scope_org_wide"}}</option>
              {{- range $programs}}
              <option value="{{.ID}}" data-path="{{.Path}}"{{if eq .ID $grant.ScopeID}} selected{{end}}>{{.Name}}</option>
              {{- end}}
            </select>
            {{- if $grant.Granted}}
            <p class="hint grant-scope-current">
              {{t "admin.users.grant_scope_current"}}
              {{- if $grant.ScopeName}} {{$grant.ScopeName}}{{else}} {{t "admin.users.grant_scope_org_wide"}}{{end}}
            </p>
            {{- end}}
            <p class="hint">{{t "admin.users.grant_scope_hint"}}</p>
          </div>
          {{- end}}
        </fieldset>
        {{- end}}
      </div>
      {{- else}}
      <p class="hint">{{t "admin.users.no_groups"}}</p>
      {{- end}}
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">{{t "admin.users.save_grants"}}</button>
      </div>
    </form>
  </section>
  {{- end}}
{{template "shell-close" .}}
{{- end}}
