{{/*
  p26.77 "All" landing (GET /more, AnyUser; also GET / — p26.78). A card grid of EVERY
  navigable destination: every top-level section, its sub-items, and every report the
  user is granted, grouped into labeled sections. Cards are perm-gated server-side
  (allSections), so a user only sees what they can reach — a report card appears iff the
  user could open the report (per-report grant), not merely "has some grant". Each card
  is a labeled, clickable tile linking to its destination. Self-contained shell page;
  .Page is a hubPageModel. Every string via {{t}} (rule 9); no inline script (rule 12).

  This is the reusable card-grid landing — the "cards linking to destinations" pattern.
*/ -}}

{{- /* p28.12: ONE reusable card-section partial (dot is an allSection). The "All"
     landing and the /reports index both render their card grids through this, so the
     two pages match exactly (same .hub-section / .hub-cards / .hub-card classes). Each
     page owns its own heading + empty-state; only the section body lives here. */ -}}
{{define "card-section" -}}
<section class="hub-section">
  <h2 class="hub-section-title">{{.Label}}</h2>
  {{template "hub-cards" .Cards}}
</section>
{{- end}}

{{- /* p13.2 (cards): the bare card grid (no section header). Dot is a []hubCardItem.
     Extracted from card-section so the /admin index — a SINGLE group whose name is the
     page title — can render the same card look under its own <h1> WITHOUT a redundant
     per-section <h2>. /more and /reports still go through card-section (unchanged
     output); only the inner <ul> lives here now. */ -}}
{{define "hub-cards" -}}
<ul class="hub-cards">
  {{range .}}
  <li class="hub-card">
    <a class="hub-card-link" href="{{.Href}}">
      <span class="hub-card-label">{{if .Icon}}{{template "icon" .Icon}}{{end}}{{.Label}}</span>
      {{- if .Desc}}<span class="hub-card-desc">{{.Desc}}</span>{{end}}
    </a>
  </li>
  {{end}}
</ul>
{{- end}}

{{define "all-cards" -}}
{{- /* Dot is a hubPageModel. */ -}}
{{range .Sections}}
{{template "card-section" .}}
{{else}}
<p class="hub-empty">{{t "all.empty"}}</p>
{{end}}
{{- end}}

{{define "more.tmpl" -}}
{{template "shell-open" (shellTitle . (t "all.title"))}}
  {{- with .Page}}
  <h1>{{t .TitleKey}}</h1>
  <p class="hint">{{t .IntroKey}}</p>
  {{template "all-cards" .}}
  {{- end}}
{{template "shell-close" .}}
{{- end}}
