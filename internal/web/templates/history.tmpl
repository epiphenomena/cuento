{{/*
  p12.4 transaction history panel (/transactions/{id}/history, TxnRead). A read-only
  timeline reconstructed from the version twins: one entry per change, showing the
  actor, the (user-formatted) date, an op label (created/updated/voided), the header
  field diffs, and the split-set diffs (added/removed/changed, INCLUDING fund and
  functional-class deltas). Diffs are already resolved to display strings by the
  handler (names in the request language, amounts through the money formatter); this
  template only lays them out. .Page is a historyPageModel.

  Each field diff renders as OLD -> NEW; a one-sided diff (a create's initial value,
  a removed field) shows just the present side. Every label is an i18n key (rule 9);
  no inline script/style (rule 12).
*/ -}}

{{/* history-diff: one field change (label + old/new). Shared by header and split
     diffs. Data is a histDiffView. */ -}}
{{define "history-diff" -}}
<li class="hist-diff">
  <span class="hist-field">{{t .Label}}</span>
  {{- if and .Old .New}}
  <span class="hist-old">{{.Old}}</span>
  <span class="hist-arrow" aria-hidden="true">-&gt;</span>
  <span class="hist-new">{{.New}}</span>
  {{- else if .New}}
  <span class="hist-new">{{.New}}</span>
  {{- else}}
  <span class="hist-old">{{.Old}}</span>
  {{- end}}
</li>
{{- end}}

{{define "history.tmpl" -}}
{{template "shell-open" (shellTitle . (t "history.title"))}}
  {{- with .Page}}
  <h1>{{t "history.title"}}</h1>
  <p><a href="/transactions/{{.TxnID}}/edit">{{t "history.back_to_txn"}}</a></p>

  <ol class="history-timeline">
    {{range .Entries}}
    <li class="hist-entry">
      <div class="hist-head">
        <span class="hist-op">{{t .OpKey}}</span>
        <span class="hist-actor">{{.Actor}}</span>
        <time class="hist-date">{{.Date}}</time>
      </div>

      {{if .HeaderDiffs}}
      <ul class="hist-header-diffs">
        {{range .HeaderDiffs}}{{template "history-diff" .}}{{end}}
      </ul>
      {{end}}

      {{range .SplitDiffs}}
      <div class="hist-split">
        <span class="hist-split-op">{{t .OpKey}}</span>
        <span class="hist-split-line">{{tn "history.split.line" .Line}}</span>
        {{if .Diffs}}
        <ul class="hist-split-diffs">
          {{range .Diffs}}{{template "history-diff" .}}{{end}}
        </ul>
        {{end}}
      </div>
      {{end}}
    </li>
    {{else}}
    <li class="hist-empty">{{t "history.empty"}}</li>
    {{end}}
  </ol>
  {{- end}}
{{template "shell-close" .}}
{{- end}}
